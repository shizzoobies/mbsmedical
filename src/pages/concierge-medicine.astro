---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Concierge Medicine" description="Direct primary care with same-day access, extended visits, 24/7 provider messaging, and a membership model built around your health. Telehealth across Florida.">

  <!-- Hero: split layout -->
  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #0a1a14 0%, #080808 50%, #0a0f1a 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <span class="label text-primary block mb-5">Concierge Medicine</span>
          <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
            A provider who is<br /><em class="text-primary italic">actually available</em>
          </h1>
          <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
            Direct primary care with same-day appointments, unlimited messaging, and extended visit times. No insurance middlemen. Just a real relationship with a provider who knows your history.
          </p>
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Join as a Member</a>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="img-placeholder">[ Image Placeholder ]</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Breakdown -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <h2 class="sr-only">What concierge medicine includes</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-7 sm:p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Same-Day Access</h3>
          <p class="text-text/50 text-sm leading-relaxed">Same-day and next-day appointments, available when you need care — not three weeks from now.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-7 sm:p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">24/7 Messaging</h3>
          <p class="text-text/50 text-sm leading-relaxed">Direct messaging access to your provider around the clock. No call centers, no nurse triage queues.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-7 sm:p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Extended Visits</h3>
          <p class="text-text/50 text-sm leading-relaxed">Appointments designed to actually address your concerns — not rushed 10-minute windows with a stranger.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-7 sm:p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">No Insurance Billing</h3>
          <p class="text-text/50 text-sm leading-relaxed">Flat annual membership. No surprise bills, no prior authorizations, no insurance company between you and your care.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-20 sm:py-28 relative" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <AsciiHover charset="+" cellSize={24} radius={120} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <span class="label text-primary block mb-5">What's Included</span>
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text mb-8">
            Comprehensive care,<br />one <em class="text-primary italic">membership</em>
          </h2>
          <ul class="space-y-4 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Annual wellness exam and comprehensive health review</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Unlimited telehealth visits with your dedicated provider</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Direct messaging — questions answered within hours</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Lab ordering and results interpretation included</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Specialist coordination and referral management</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Personalized wellness planning updated annually</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Prescription management and refills without extra visits</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="img-placeholder">[ Image Placeholder ]</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Membership Tags -->
  <section class="py-20 sm:py-28 relative" style="background: linear-gradient(160deg, #0a0f1a 0%, #080808 50%, #0f1a14 100%);">
    <AsciiHover charset="·" cellSize={28} radius={100} baseOpacity={0.025} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <span class="label text-primary block mb-5">Membership Benefits</span>
        <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
          {['Same-Day Appointments', 'Extended Visit Times', '24/7 Messaging', 'No Insurance Billing', 'Direct Provider Access', 'Annual Wellness Plan', 'Specialist Coordination', 'Lab Interpretation'].map((c) => (
            <span class="font-ui text-[10px] font-semibold uppercase tracking-[0.12em] px-5 py-2.5 rounded-full border border-border text-text/60 hover:border-primary hover:text-primary transition-all duration-300">{c}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Ready for a provider<br />who is <em class="text-primary italic">always there</em>?
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Join as a member and experience what primary care is supposed to feel like.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Join as a Member</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .img-placeholder {
    aspect-ratio: 16/9;
    background: rgba(255,255,255,0.03);
    border: 1px dashed rgba(255,255,255,0.1);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.15);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
