---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Anxiety Management" description="Clinical evaluation and medication management for anxiety disorders. Compassionate telehealth care across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #14101e 0%, #080808 50%, #0a1410 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-accent block mb-5">Anxiety Management</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Anxiety doesn't<br />define <em class="text-accent italic">you</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
          Clinical evaluation and medication management for anxiety. A provider who takes the time to understand what you're going through.
        </p>
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
      </div>
    </div>
  </section>

  <!-- Clinical Approach -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Our Approach</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Structured care for<br />lasting <em class="text-accent italic">relief</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Clinical Assessment</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Structured symptom evaluation</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Comprehensive health history review</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Identification of triggers and patterns</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Medication Management</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> SSRI and SNRI evaluation</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Careful dosing and titration</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Side effect monitoring and adjustments</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Ongoing Support</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Regular follow-up appointments</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Treatment plan adjustments as needed</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Progress tracking and goal review</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Treat -->
  <section class="py-28 sm:py-36" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Conditions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What we <em class="text-accent italic">treat</em></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Generalized Anxiety</h3>
          <p class="text-text/50 text-sm leading-relaxed">Persistent, excessive worry that interferes with daily activities and overall well-being.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Social Anxiety</h3>
          <p class="text-text/50 text-sm leading-relaxed">Intense fear or avoidance of social situations driven by concerns about judgment or embarrassment.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Panic Disorder</h3>
          <p class="text-text/50 text-sm leading-relaxed">Recurrent panic attacks with sudden onset of physical symptoms and overwhelming fear.</p>
        </div>
        <div class="reveal reveal-delay-4 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Anxiety with Depression</h3>
          <p class="text-text/50 text-sm leading-relaxed">Co-occurring anxiety and depressive symptoms that require an integrated treatment approach.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 sm:py-36 relative overflow-hidden" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <AsciiHover charset="01" cellSize={24} radius={120} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Common Questions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What to <em class="text-accent italic">expect</em></h2>
      </div>
      <div class="max-w-3xl space-y-4">
        {[
          { q: 'Can anxiety be treated via telehealth?', a: 'Yes. Anxiety is one of the most commonly treated conditions through telehealth. Your provider can conduct thorough evaluations, prescribe medication, and monitor your progress — all through secure video visits.' },
          { q: 'Do you prescribe anxiety medication?', a: 'Yes. After a comprehensive evaluation, your provider may prescribe SSRIs, SNRIs, or other appropriate medications based on your symptoms, health history, and treatment goals.' },
          { q: 'How often will I need follow-ups?', a: 'Follow-up frequency depends on your treatment plan. Initially, visits may be more frequent to monitor medication response. Once stabilized, your provider will set a schedule that supports long-term management.' },
        ].map((item) => (
          <details class="reveal group bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[20px]">
            <summary class="flex items-center justify-between px-5 sm:px-6 py-5 cursor-pointer text-text font-display font-light text-lg sm:text-xl">
              {item.q}
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 sm:px-6 pb-5 text-text/50 text-sm sm:text-base leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Take the first step toward <em class="text-accent italic">calm</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book your evaluation and start working with a provider who understands anxiety — and knows how to help.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-accent">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
