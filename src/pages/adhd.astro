---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="ADHD Management" description="ADHD evaluation and medication management for adults. Structured assessment with ongoing telehealth support across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #14101e 0%, #080808 50%, #0a1410 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-accent block mb-5">ADHD Management</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Focus, clarity,<br />and a real <em class="text-accent italic">plan</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
          ADHD evaluation and medication management for adults. Structured assessment with ongoing provider support.
        </p>
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Our Approach</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">A clear process from<br />evaluation to <em class="text-accent italic">results</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Structured Evaluation</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Validated symptom screening tools</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Detailed history review and timeline</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Functional impact assessment</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Medication Options</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Stimulant and non-stimulant evaluations</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Careful titration and dosing</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Risk-benefit discussion for each option</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Ongoing Monitoring</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Regular check-ins and progress reviews</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Dose optimization over time</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Side effect management and adjustments</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- How ADHD Shows Up in Adults -->
  <section class="py-28 sm:py-36" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">How ADHD Shows Up in Adults</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">It's not just about<br /><em class="text-accent italic">attention</em></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Difficulty Focusing</h3>
          <p class="text-text/50 text-sm leading-relaxed">Trouble sustaining attention on tasks, especially ones that feel repetitive or unengaging.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Procrastination</h3>
          <p class="text-text/50 text-sm leading-relaxed">Consistently putting off tasks despite knowing the consequences, often feeling stuck.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Restlessness</h3>
          <p class="text-text/50 text-sm leading-relaxed">An internal sense of restlessness or the need to always be doing something.</p>
        </div>
        <div class="reveal reveal-delay-4 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Impulsivity</h3>
          <p class="text-text/50 text-sm leading-relaxed">Acting or speaking without thinking, making quick decisions that don't always pan out.</p>
        </div>
        <div class="reveal reveal-delay-5 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Time Management Struggles</h3>
          <p class="text-text/50 text-sm leading-relaxed">Chronic lateness, underestimating how long things take, and difficulty prioritizing.</p>
        </div>
        <div class="reveal reveal-delay-6 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-xl text-text mb-3">Emotional Dysregulation</h3>
          <p class="text-text/50 text-sm leading-relaxed">Intense emotional reactions, frustration, or mood shifts that feel disproportionate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 sm:py-36 relative overflow-hidden" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <AsciiHover charset="01" cellSize={24} radius={120} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Common Questions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What to <em class="text-accent italic">expect</em></h2>
      </div>
      <div class="max-w-3xl space-y-4">
        {[
          { q: 'Do you diagnose ADHD?', a: 'We conduct structured clinical evaluations for ADHD in adults. This includes validated screening tools, a detailed history review, and an assessment of how symptoms affect your daily functioning.' },
          { q: 'Do you prescribe stimulant medications?', a: 'When clinically appropriate, yes. Your provider will evaluate whether stimulant or non-stimulant medication is the best fit based on your history, symptoms, and overall health profile.' },
          { q: 'Can ADHD be managed via telehealth?', a: 'Yes. ADHD evaluation, medication management, and ongoing monitoring are all well-suited for telehealth. Secure video visits allow for thorough assessments and regular follow-ups from the comfort of your home.' },
        ].map((item) => (
          <details class="reveal group bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[20px]">
            <summary class="flex items-center justify-between px-5 sm:px-6 py-5 cursor-pointer text-text font-display font-light text-lg sm:text-xl">
              {item.q}
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 sm:px-6 pb-5 text-text/50 text-sm sm:text-base leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Get the support you <em class="text-accent italic">need</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book your evaluation and start working with a provider who understands adult ADHD.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-accent">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
