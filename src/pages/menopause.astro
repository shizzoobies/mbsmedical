---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Menopause" description="Comprehensive menopause management from a provider who listens. Hot flashes, mood changes, sleep disruption — we address the full picture. MBS Medical telehealth across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #1a0f14 0%, #080808 50%, #14101e 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="max-w-xl">
          <span class="label text-accent block mb-5">Menopause</span>
          <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
            Navigate menopause<br />with <em class="text-accent italic">real support</em>
          </h1>
          <p class="text-text/50 text-base sm:text-lg leading-relaxed mb-10">
            Comprehensive menopause management from a provider who listens. Hot flashes, mood changes, sleep disruption — we address the full picture.
          </p>
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
        </div>
        <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center">
          <span class="text-text-muted text-sm">Image Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Our Approach</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Care that sees the <em class="text-accent italic">whole picture</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Symptom Management</h3>
          <p class="text-text/50 text-sm leading-relaxed">Hot flashes, night sweats, mood swings, and sleep disruption — we develop a targeted plan to manage the symptoms that are affecting your daily life.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Hormone Evaluation</h3>
          <p class="text-text/50 text-sm leading-relaxed">Lab work to understand your hormonal picture and guide treatment decisions. We use data — not guesswork — to build your care plan.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Treatment Options</h3>
          <p class="text-text/50 text-sm leading-relaxed">Hormone replacement therapy discussion, non-hormonal alternatives, and lifestyle strategies — we walk through every option so you can make an informed decision.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Address -->
  <section class="py-28 sm:py-36 border-t border-border relative" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·∘⊹" cellSize={24} radius={140} baseOpacity={0.03} />
    <div class="relative z-2 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">What We Address</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Common symptoms we <em class="text-accent italic">treat</em></h2>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Hot Flashes & Night Sweats</h3>
          <p class="text-text/50 text-sm leading-relaxed">Sudden heat, flushing, and drenching sweats that disrupt your day and your sleep. We have effective strategies to reduce their frequency and intensity.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Mood Changes</h3>
          <p class="text-text/50 text-sm leading-relaxed">Irritability, anxiety, and low mood that feel out of character. Hormonal shifts play a real role, and we address them as part of your care plan.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Sleep Disruption</h3>
          <p class="text-text/50 text-sm leading-relaxed">Difficulty falling asleep, staying asleep, or waking up exhausted. Menopause-related sleep issues require a targeted approach that goes beyond general advice.</p>
        </div>
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Weight Changes</h3>
          <p class="text-text/50 text-sm leading-relaxed">Unexplained weight gain, especially around the midsection, that doesn't respond to what used to work. We look at the hormonal factors driving these changes.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Brain Fog & Fatigue</h3>
          <p class="text-text/50 text-sm leading-relaxed">Difficulty concentrating, forgetfulness, and a persistent sense of exhaustion. These are real symptoms with real solutions — not just a normal part of aging.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Low Libido</h3>
          <p class="text-text/50 text-sm leading-relaxed">Changes in desire and intimacy are common during menopause. We discuss this openly and explore options that can help restore your sense of well-being.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Common Questions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What you need to <em class="text-accent italic">know</em></h2>
      </div>
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl">
        <div class="reveal">
          <h3 class="font-display font-light text-2xl text-text mb-3">Can menopause be managed via telehealth?</h3>
          <p class="text-text/50 text-base leading-relaxed">Absolutely. Most menopause management — symptom evaluation, lab ordering and review, medication prescribing, and ongoing adjustments — can be done effectively through telehealth visits.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <h3 class="font-display font-light text-2xl text-text mb-3">Do you prescribe HRT?</h3>
          <p class="text-text/50 text-base leading-relaxed">Yes, when appropriate. We evaluate your symptoms, health history, and risk factors to determine if hormone replacement therapy is a safe and effective option for you. We also discuss non-hormonal alternatives.</p>
        </div>
        <div class="reveal reveal-delay-2">
          <h3 class="font-display font-light text-2xl text-text mb-3">When should I seek help for menopause symptoms?</h3>
          <p class="text-text/50 text-base leading-relaxed">If your symptoms are interfering with your quality of life — disrupting your sleep, affecting your mood, or making daily tasks harder — it's time to talk to a provider. You don't have to push through it on your own.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          You don't have to<br />do this <em class="text-accent italic">alone</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit with a provider who understands menopause and will work with you to find real solutions — not just tell you it's normal.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-accent">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
