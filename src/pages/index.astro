---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Home" description="MBS Medical — Telehealth primary care, weight loss, and TRT evaluation across Florida. Cash pay, same-week appointments, one consistent provider.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-warm-light via-bg to-warm/30">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 right-1/4 w-72 h-72 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-6">
          <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
          Telehealth across Florida
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl text-primary-dark leading-tight mb-6">
          Medical care that<br />
          <span class="text-accent">starts with you</span>
        </h1>
        <p class="text-text-light text-lg sm:text-xl leading-relaxed mb-10 max-w-2xl">
          Direct access to a licensed provider who knows your history, your goals, and your health — not just your chart. Cash pay, no insurance hassles, same-week appointments.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white px-8 py-3.5 rounded-full text-base font-semibold transition-all hover:shadow-lg hover:shadow-primary/25">
            Book a Visit
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/services/" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-warm-light text-primary-dark px-8 py-3.5 rounded-full text-base font-semibold border border-warm-dark/20 transition-all">
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-white border-y border-warm-dark/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-sm font-medium text-text">Same-Week Appointments</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-sm font-medium text-text">Cash Pay, No Insurance</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <p class="text-sm font-medium text-text">HIPAA-Compliant Portal</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <p class="text-sm font-medium text-text">One Consistent Provider</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow="What We Offer" title="Healthcare built around your needs" subtitle="Three focused services designed around continuity of care, honest evaluation, and real provider access." />
      <div class="grid md:grid-cols-3 gap-6">
        <ServiceCard title="Primary Care" description="Routine visits, chronic condition management, and medication oversight — all from a provider who knows your full history." href="/primary-care/" icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>' />
        <ServiceCard title="Weight Loss" description="Clinically supervised weight management with GLP-1 evaluation, personalized plans, and ongoing monitoring." href="/weight-loss/" icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>' />
        <ServiceCard title="TRT Evaluation" description="Lab-driven testosterone assessment with honest evaluation — focused on your health, not a sales pitch." href="/trt/" icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>' />
      </div>
    </div>
  </section>

  <!-- Why MBS -->
  <section class="py-20 sm:py-28 bg-warm-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow="Why MBS Medical" title="Care that's different by design" subtitle="We built this practice around what healthcare should feel like — personal, straightforward, and focused on you." />
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 bg-accent/20 rounded-full flex items-center justify-center mt-1">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary-dark mb-1.5">One provider, every visit</h3>
            <p class="text-text-light text-sm leading-relaxed">No rotating staff. You see the same provider who knows your history, medications, and goals.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 bg-accent/20 rounded-full flex items-center justify-center mt-1">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary-dark mb-1.5">No insurance red tape</h3>
            <p class="text-text-light text-sm leading-relaxed">Cash pay means no surprise bills, no prior authorizations, and no denied claims.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 bg-accent/20 rounded-full flex items-center justify-center mt-1">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary-dark mb-1.5">Telehealth across Florida</h3>
            <p class="text-text-light text-sm leading-relaxed">Quality care from wherever you are. No waiting rooms, no commute, no wasted time.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 bg-accent/20 rounded-full flex items-center justify-center mt-1">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary-dark mb-1.5">Goal-oriented care plans</h3>
            <p class="text-text-light text-sm leading-relaxed">Your care plan evolves with you. We track progress, adjust treatments, and keep your goals front and center.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Preview -->
  <section class="py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow="Your Care Team" title="Experienced providers behind your care" subtitle="A military-trained PA-C backed by two board-certified physicians with decades of clinical experience." />
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-24 h-24 mx-auto bg-warm rounded-full flex items-center justify-center mb-4">
            <svg class="w-10 h-10 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-heading text-lg text-primary-dark">David, PA-C</h3>
          <p class="text-accent text-sm font-medium mb-2">Founder & Primary Provider</p>
          <p class="text-text-light text-xs">12 years U.S. Army service</p>
        </div>
        <div class="text-center">
          <div class="w-24 h-24 mx-auto bg-warm rounded-full flex items-center justify-center mb-4">
            <svg class="w-10 h-10 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-heading text-lg text-primary-dark">Dr. Eric Folkens, MD</h3>
          <p class="text-accent text-sm font-medium mb-2">Supervising Physician</p>
          <p class="text-text-light text-xs">34+ years family medicine</p>
        </div>
        <div class="text-center">
          <div class="w-24 h-24 mx-auto bg-warm rounded-full flex items-center justify-center mb-4">
            <svg class="w-10 h-10 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-heading text-lg text-primary-dark">Dr. Mark Dawson, MD</h3>
          <p class="text-accent text-sm font-medium mb-2">Supervising Physician</p>
          <p class="text-text-light text-xs">30+ years gastroenterology</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/about/" class="inline-flex items-center gap-2 text-primary font-medium hover:text-primary-light transition-colors">
          Meet the full team
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-28 bg-primary">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl text-white mb-4">Ready to get started?</h2>
      <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto">Book a visit and connect with a provider who takes the time to understand your health. Same-week availability.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-white text-primary-dark px-8 py-3.5 rounded-full text-base font-semibold hover:bg-warm-light transition-all hover:shadow-lg">
          Book a Visit
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center gap-2 bg-white/15 text-white px-8 py-3.5 rounded-full text-base font-semibold hover:bg-white/25 transition-all">
          Ask a Question
        </a>
      </div>
    </div>
  </section>

</Layout>
