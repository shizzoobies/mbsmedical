---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="MBS Medical — Telehealth primary care, weight loss, and TRT evaluation across Florida. Cash pay, same-week appointments, one consistent provider.">

  <!-- ============================================ -->
  <!-- HERO — Full viewport, left-aligned text      -->
  <!-- ============================================ -->
  <section class="relative h-screen min-h-[700px] flex items-end overflow-hidden">
    <!-- Video Background -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: 70% 60%;"
    >
      <source src="/images/flag-intro.mp4" type="video/mp4" />
    </video>

    <!-- Overlay -->
    <div class="absolute inset-0 hero-overlay"></div>

    <!-- Content — left aligned, bottom portion -->
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 pb-28 sm:pb-36 w-full">
      <h1 class="font-display font-light text-[clamp(3rem,8vw,6.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8 max-w-4xl">
        Medical care<br />
        that <em class="text-primary italic">starts</em><br />
        with you
      </h1>
      <p class="text-text/70 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
        Direct access to a licensed provider who knows your history, your goals, and your health. Cash pay, no insurance, same-week appointments across Florida.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300"
        >
          Book a Visit
        </a>
        <a
          href="/services/"
          class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-transparent text-text border border-text/30 px-7 py-3 rounded-[4px] hover:border-accent hover:text-accent transition-all duration-300"
        >
          View Our Services
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce-slow">
      <svg class="w-5 h-5 text-text/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SERVICES INTRO — left-aligned heading        -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">What We Offer</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text mb-6">
          Three focused services,<br />
          one <em class="text-primary italic">consistent</em> provider
        </h2>
        <p class="text-text/50 text-base leading-relaxed max-w-[540px]">
          Every service we offer is built around continuity of care, honest evaluation, and real access to a provider who knows your full health picture.
        </p>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SERVICES — Horizontal blocks, alternating    -->
  <!-- ============================================ -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <!-- Service 1: Primary Care -->
      <a href="/primary-care/" class="reveal group block py-12 lg:py-16 border-t border-border">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
          <div class="lg:col-span-1">
            <span class="font-display font-light text-6xl lg:text-7xl text-text-muted group-hover:text-accent/40 transition-colors duration-500">01</span>
          </div>
          <div class="lg:col-span-5">
            <h3 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Primary Care</h3>
            <p class="text-text/50 text-base leading-relaxed mb-5 max-w-[480px]">Ongoing care from a provider who knows your history, your medications, and your goals. Routine visits, chronic condition management, and medication oversight.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              View Service
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="lg:col-span-6">
            <div class="aspect-[16/10] rounded-2xl overflow-hidden group-hover:border-accent/20 transition-all duration-500">
              <img src="/images/primary-care.png" alt="Primary Care" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
        </div>
      </a>

      <!-- Service 2: Weight Loss (reversed) -->
      <a href="/weight-loss/" class="reveal group block py-12 lg:py-16 border-t border-border">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
          <div class="lg:col-span-6 lg:order-1">
            <div class="aspect-[16/10] rounded-2xl overflow-hidden group-hover:border-accent/20 transition-all duration-500">
              <img src="/images/weight-loss.png" alt="Weight Loss" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
          <div class="lg:col-span-1 lg:order-2 lg:text-right">
            <span class="font-display font-light text-6xl lg:text-7xl text-text-muted group-hover:text-accent/40 transition-colors duration-500">02</span>
          </div>
          <div class="lg:col-span-5 lg:order-3">
            <h3 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Weight Loss</h3>
            <p class="text-text/50 text-base leading-relaxed mb-5 max-w-[480px]">Clinically supervised weight management with GLP-1 receptor agonist evaluation. Personalized plans built around your health history and goals.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              View Service
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </div>
      </a>

      <!-- Service 3: TRT -->
      <a href="/trt/" class="reveal group block py-12 lg:py-16 border-t border-b border-border">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
          <div class="lg:col-span-1">
            <span class="font-display font-light text-6xl lg:text-7xl text-text-muted group-hover:text-accent/40 transition-colors duration-500">03</span>
          </div>
          <div class="lg:col-span-5">
            <h3 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">TRT Evaluation</h3>
            <p class="text-text/50 text-base leading-relaxed mb-5 max-w-[480px]">Lab-driven testosterone assessment with an honest, evaluation-first approach. We start with your symptoms and labs — not a sales pitch.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              View Service
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="lg:col-span-6">
            <div class="aspect-[16/10] rounded-2xl overflow-hidden group-hover:border-accent/20 transition-all duration-500">
              <img src="/images/trt.png" alt="TRT Evaluation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
        </div>
      </a>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- STATS BAR                                    -->
  <!-- ============================================ -->
  <section class="py-20 sm:py-28 border-t border-b border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid grid-cols-2 lg:grid-cols-4 gap-8 lg:divide-x lg:divide-border">
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">12+</p>
          <p class="label text-text-muted">Years Military Service</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">64+</p>
          <p class="label text-text-muted">Years Combined Experience</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">FL</p>
          <p class="label text-text-muted">Statewide Telehealth</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">$0</p>
          <p class="label text-text-muted">Insurance Hassle</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- TEAM — Side-by-side portraits                -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">Your Care Team</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text max-w-2xl">
          The providers behind<br />
          your <em class="text-primary italic">care</em>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <!-- David -->
        <div class="reveal reveal-delay-1 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border">
            <img src="/images/david.png" alt="David, PA-C" class="w-full h-full object-cover" />
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">David, PA-C</h3>
          <p class="label text-primary mb-2">Founder & Primary Provider</p>
          <p class="text-text/40 text-xs">12 years U.S. Army &middot; Licensed FL</p>
        </div>
        <!-- Julie -->
        <div class="reveal reveal-delay-2 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border bg-surface-light flex items-center justify-center">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">Julie Vera Rivas</h3>
          <p class="label text-accent mb-2">MSN, APRN, AANP-C</p>
          <p class="text-text/40 text-xs">Nurse Practitioner</p>
        </div>
        <!-- Dr. Folkens -->
        <div class="reveal reveal-delay-3 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border bg-surface-light flex items-center justify-center">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">Dr. Eric Folkens</h3>
          <p class="label text-accent mb-2">Supervising Physician</p>
          <p class="text-text/40 text-xs">ABFM Certified &middot; 34+ years</p>
        </div>
        <!-- Dr. Dawson -->
        <div class="reveal reveal-delay-4 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border bg-surface-light flex items-center justify-center">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">Dr. Mark Dawson</h3>
          <p class="label text-accent mb-2">Supervising Physician</p>
          <p class="text-text/40 text-xs">30+ years gastroenterology</p>
        </div>
      </div>

      <div class="reveal text-center mt-12">
        <a href="/about/" class="inline-flex items-center gap-3 label text-primary hover:text-accent hover:gap-5 transition-all duration-300">
          Meet the full team
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- CTA — Split layout with border accent        -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div class="border-l-[3px] border-primary pl-8 sm:pl-10">
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text">
            Ready to start<br />
            your <em class="text-primary italic">journey</em>?
          </h2>
        </div>

        <div>
          <p class="text-text/50 text-base leading-relaxed mb-8 max-w-[480px]">
            Book a visit and connect with a provider who takes the time to understand your health. Same-week telehealth appointments, no insurance needed, statewide across Florida.
          </p>
          <a
            href="https://mbsmedical.practicebetter.io"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300"
          >
            Book a Free Consultation
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>

<!-- Scroll reveal observer -->
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
