---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="MBS Medical — Telehealth primary care, weight loss, and TRT evaluation across Florida. Cash pay, same-week appointments, one consistent provider.">

  <!-- ============================================ -->
  <!-- HERO — Full-screen cinematic video           -->
  <!-- ============================================ -->
  <section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
    <!-- Video Background -->
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/hero-poster.jpg"
      class="absolute inset-0 w-full h-full object-cover"
    >
      <!-- Replace this src with your own video file -->
      <source src="https://videos.pexels.com/video-files/5452029/5452029-uhd_2560_1440_30fps.mp4" type="video/mp4" />
    </video>

    <!-- Overlay -->
    <div class="absolute inset-0 hero-overlay"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl xl:text-8xl text-white leading-[1.1] mb-6 tracking-tight">
        Medical care that<br />starts with you
      </h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-xl mx-auto mb-10 font-light">
        One provider. Your history. Your goals. Every visit.
      </p>
      <a
        href="https://mbsmedical.practicebetter.io"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-white text-surface-dark px-10 py-4 rounded-full text-base font-semibold hover:bg-primary hover:text-white transition-all duration-300 hover:shadow-2xl hover:shadow-primary/30 hover:scale-105"
      >
        Book a Visit
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce-slow">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- FLOATING STATS BAR                           -->
  <!-- ============================================ -->
  <section class="relative z-20 -mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal bg-surface-dark/95 backdrop-blur-xl rounded-2xl border border-white/5 shadow-2xl">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
          <div class="px-6 py-6 text-center">
            <p class="text-primary text-2xl font-bold mb-1">12+</p>
            <p class="text-white/50 text-xs uppercase tracking-widest">Years Military Service</p>
          </div>
          <div class="px-6 py-6 text-center">
            <p class="text-primary text-2xl font-bold mb-1">Same</p>
            <p class="text-white/50 text-xs uppercase tracking-widest">Week Appointments</p>
          </div>
          <div class="px-6 py-6 text-center">
            <p class="text-primary text-2xl font-bold mb-1">All FL</p>
            <p class="text-white/50 text-xs uppercase tracking-widest">Statewide Telehealth</p>
          </div>
          <div class="px-6 py-6 text-center">
            <p class="text-primary text-2xl font-bold mb-1">$0</p>
            <p class="text-white/50 text-xs uppercase tracking-widest">Insurance Hassle</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SERVICES — Full-width immersive blocks       -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section intro -->
      <div class="reveal text-center mb-20">
        <span class="text-primary font-semibold text-sm uppercase tracking-[0.2em] mb-4 block">What We Do</span>
        <h2 class="font-heading text-4xl sm:text-5xl text-text mb-4">Three services. One provider.</h2>
      </div>

      <!-- Service 1: Primary Care -->
      <a href="/primary-care/" class="reveal group block mb-16 lg:mb-24">
        <div class="grid lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-2">
            <span class="text-8xl lg:text-9xl font-heading text-warm-dark/40 group-hover:text-primary/30 transition-colors duration-500">01</span>
          </div>
          <div class="lg:col-span-5">
            <h3 class="font-heading text-3xl sm:text-4xl text-text group-hover:text-primary transition-colors duration-300 mb-4">Primary Care</h3>
            <p class="text-text-light text-lg leading-relaxed mb-4">Ongoing care from a provider who knows your history, your medications, and your goals. Routine visits, chronic condition management, and medication oversight — all in one place.</p>
            <span class="inline-flex items-center gap-2 text-primary font-medium group-hover:gap-4 transition-all duration-300">
              Learn more
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="lg:col-span-5">
            <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-primary/10 to-primary/5 border border-primary/10 flex items-center justify-center group-hover:from-primary/20 group-hover:to-primary/10 transition-all duration-500">
              <svg class="w-20 h-20 text-primary/30 group-hover:text-primary/50 transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Divider -->
      <div class="border-t border-warm-dark/20 mb-16 lg:mb-24"></div>

      <!-- Service 2: Weight Loss (reversed) -->
      <a href="/weight-loss/" class="reveal group block mb-16 lg:mb-24">
        <div class="grid lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-5 lg:order-1">
            <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-accent/10 to-accent/5 border border-accent/10 flex items-center justify-center group-hover:from-accent/20 group-hover:to-accent/10 transition-all duration-500">
              <svg class="w-20 h-20 text-accent/30 group-hover:text-accent/50 transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
          </div>
          <div class="lg:col-span-2 lg:order-2 lg:text-right">
            <span class="text-8xl lg:text-9xl font-heading text-warm-dark/40 group-hover:text-accent/30 transition-colors duration-500">02</span>
          </div>
          <div class="lg:col-span-5 lg:order-3">
            <h3 class="font-heading text-3xl sm:text-4xl text-text group-hover:text-accent transition-colors duration-300 mb-4">Weight Loss</h3>
            <p class="text-text-light text-lg leading-relaxed mb-4">Clinically supervised weight management with GLP-1 receptor agonist evaluation. Personalized plans built around your health, not a script.</p>
            <span class="inline-flex items-center gap-2 text-accent font-medium group-hover:gap-4 transition-all duration-300">
              Learn more
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </div>
      </a>

      <!-- Divider -->
      <div class="border-t border-warm-dark/20 mb-16 lg:mb-24"></div>

      <!-- Service 3: TRT -->
      <a href="/trt/" class="reveal group block">
        <div class="grid lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-2">
            <span class="text-8xl lg:text-9xl font-heading text-warm-dark/40 group-hover:text-primary/30 transition-colors duration-500">03</span>
          </div>
          <div class="lg:col-span-5">
            <h3 class="font-heading text-3xl sm:text-4xl text-text group-hover:text-primary transition-colors duration-300 mb-4">TRT Evaluation</h3>
            <p class="text-text-light text-lg leading-relaxed mb-4">Lab-driven testosterone assessment with an honest, evaluation-first approach. We start with your symptoms and labs — not a sales pitch.</p>
            <span class="inline-flex items-center gap-2 text-primary font-medium group-hover:gap-4 transition-all duration-300">
              Learn more
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="lg:col-span-5">
            <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-primary/10 to-primary/5 border border-primary/10 flex items-center justify-center group-hover:from-primary/20 group-hover:to-primary/10 transition-all duration-500">
              <svg class="w-20 h-20 text-primary/30 group-hover:text-primary/50 transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            </div>
          </div>
        </div>
      </a>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- BOLD STATEMENT — Why MBS                     -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 bg-surface-dark overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="reveal text-center mb-20">
        <h2 class="font-heading text-4xl sm:text-5xl lg:text-6xl text-white leading-tight mb-6">
          One provider.<br />
          <span class="text-primary">Your history. Your goals.</span><br />
          Every visit.
        </h2>
        <p class="text-white/40 text-lg max-w-2xl mx-auto">
          We built this practice around what healthcare should feel like — personal, straightforward, and focused entirely on you.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 max-w-4xl mx-auto">
        <div class="reveal reveal-delay-1 text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <p class="text-white/70 text-sm font-medium">Same provider<br />every visit</p>
        </div>
        <div class="reveal reveal-delay-2 text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-white/70 text-sm font-medium">No insurance<br />no surprises</p>
        </div>
        <div class="reveal reveal-delay-3 text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-white/70 text-sm font-medium">Telehealth<br />all of Florida</p>
        </div>
        <div class="reveal reveal-delay-4 text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <p class="text-white/70 text-sm font-medium">HIPAA-secure<br />portal</p>
        </div>
      </div>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- TEAM — Cinematic profiles                    -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 bg-surface-darker">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="reveal text-center mb-16">
        <span class="text-primary font-semibold text-sm uppercase tracking-[0.2em] mb-4 block">Your Care Team</span>
        <h2 class="font-heading text-4xl sm:text-5xl text-white">The providers behind your care</h2>
      </div>

      <!-- David — featured -->
      <div class="reveal mb-16">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="aspect-[3/4] max-h-[500px] rounded-2xl bg-gradient-to-b from-white/10 to-white/5 border border-white/10 flex items-center justify-center">
            <svg class="w-24 h-24 text-white/15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div>
            <p class="text-primary font-semibold text-sm uppercase tracking-[0.2em] mb-3">Founder & Primary Provider</p>
            <h3 class="font-heading text-4xl sm:text-5xl text-white mb-4">David, PA-C</h3>
            <p class="text-white/50 text-lg leading-relaxed mb-6">
              Physician Associate with 12 years of U.S. Army service. Licensed in Florida. Founded MBS Medical to give patients direct, consistent access to a provider who knows their full health picture.
            </p>
            <div class="flex flex-wrap gap-3">
              <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/60 text-sm">PA-C, Licensed FL</span>
              <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/60 text-sm">12 Years U.S. Army</span>
              <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/60 text-sm">Primary Care</span>
              <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/60 text-sm">Weight Loss</span>
              <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/60 text-sm">TRT Evaluation</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Supervising physicians -->
      <div class="grid md:grid-cols-2 gap-8">
        <div class="reveal reveal-delay-1 bg-white/5 rounded-2xl border border-white/10 p-8">
          <div class="flex items-start gap-6">
            <div class="shrink-0 w-20 h-20 rounded-full bg-white/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <div>
              <p class="text-accent text-xs font-semibold uppercase tracking-widest mb-1">Supervising Physician</p>
              <h3 class="font-heading text-2xl text-white mb-2">Dr. Eric Folkens, MD</h3>
              <p class="text-white/40 text-sm leading-relaxed">ABFM Certified. 34+ years in family medicine and primary care.</p>
            </div>
          </div>
        </div>
        <div class="reveal reveal-delay-2 bg-white/5 rounded-2xl border border-white/10 p-8">
          <div class="flex items-start gap-6">
            <div class="shrink-0 w-20 h-20 rounded-full bg-white/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <div>
              <p class="text-accent text-xs font-semibold uppercase tracking-widest mb-1">Supervising Physician</p>
              <h3 class="font-heading text-2xl text-white mb-2">Dr. Mark Dawson, MD</h3>
              <p class="text-white/40 text-sm leading-relaxed">30+ years in gastroenterology and metabolic health. Oversight for GI and complex cases.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal text-center mt-12">
        <a href="/about/" class="inline-flex items-center gap-2 text-white/50 hover:text-primary font-medium transition-colors duration-300">
          Learn more about the team
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- FINAL CTA                                    -->
  <!-- ============================================ -->
  <section class="relative py-28 sm:py-36 overflow-hidden">
    <!-- Gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark via-primary to-primary-light"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.1),transparent_60%)]"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal">
        <h2 class="font-heading text-4xl sm:text-5xl lg:text-6xl text-white mb-6">
          Ready when you are
        </h2>
        <p class="text-white/70 text-lg sm:text-xl mb-12 max-w-xl mx-auto font-light">
          Same-week telehealth appointments. No insurance needed. Just you and your provider.
        </p>
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-white text-primary-dark px-10 py-4 rounded-full text-lg font-semibold hover:shadow-2xl hover:shadow-white/20 hover:scale-105 transition-all duration-300"
        >
          Book a Visit
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<!-- Scroll reveal observer -->
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
