---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="MBS Medical — Telehealth primary care, weight loss, and TRT evaluation across Florida. Cash pay, same-week appointments, one consistent provider.">

  <!-- ============================================ -->
  <!-- HERO — Full viewport, right-aligned text     -->
  <!-- ============================================ -->
  <section class="relative h-screen min-h-[700px] flex items-end overflow-hidden">
    <video
      id="hero-video"
      autoplay
      muted
      playsinline
      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[3000ms]"
      style="object-position: 70% 60%;"
    >
      <source src="/images/flag-intro.mp4" type="video/mp4" />
    </video>
    <div id="hero-overlay" class="absolute inset-0 hero-overlay transition-all duration-[3000ms]"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 pb-28 sm:pb-36 w-full flex flex-col items-end text-right">
      <h1 class="font-display font-light text-[clamp(3rem,8vw,6.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8 max-w-4xl">
        Medical care<br />
        that <em class="text-accent italic">starts</em><br />
        with you
      </h1>
      <p class="text-text/70 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10 ml-auto">
        Direct access to a licensed provider who knows your history, your goals, and your health. Cash pay, no insurance, same-week appointments across Florida.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300">
          Book a Visit
        </a>
        <a href="/services/" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-transparent text-text border border-text/30 px-7 py-3 rounded-[4px] hover:border-accent hover:text-accent transition-all duration-300">
          View Our Services
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce-slow">
      <svg class="w-5 h-5 text-text/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SCROLLING SERVICES MARQUEE                   -->
  <!-- ============================================ -->
  <section class="py-6 border-t border-b border-border overflow-hidden">
    <div class="marquee-container">
      <div class="marquee-track">
        {[1,2].map(() => (
          <Fragment>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Primary Care</span>
            </a>
            <a href="/weight-loss/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Weight Loss</span>
            </a>
            <a href="/trt/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">TRT Evaluation</span>
            </a>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Chronic Conditions</span>
            </a>
            <a href="/weight-loss/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">GLP-1 Evaluation</span>
            </a>
            <a href="/sleep/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Sleep Issues</span>
            </a>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Medication Management</span>
            </a>
            <a href="/trt/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Lab-Driven Assessment</span>
            </a>
          </Fragment>
        ))}
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SERVICES — Immersive hover cards             -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">What We Treat</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text max-w-2xl">
          Healthcare that<br />
          meets you <em class="text-accent italic">where you are</em>
        </h2>
      </div>

      <!-- Service cards — tall, image-bg, hover reveals -->
      <div class="service-grid">
        <a href="/primary-care/" class="service-card group" style="--card-img: url('/images/primary-care.png')">
          <div class="service-card-bg"></div>
          <div class="service-card-content">
            <span class="service-card-number">01</span>
            <h3 class="service-card-title">Primary<br/>Care</h3>
            <p class="service-card-desc">Routine visits, chronic condition management, and medication oversight from a provider who knows your full history.</p>
            <span class="service-card-link">
              Explore
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>

        <a href="/weight-loss/" class="service-card group" style="--card-img: url('/images/weight-loss.png')">
          <div class="service-card-bg"></div>
          <div class="service-card-content">
            <span class="service-card-number">02</span>
            <h3 class="service-card-title">Weight<br/>Loss</h3>
            <p class="service-card-desc">Clinically supervised weight management with GLP-1 receptor agonist evaluation. Personalized plans, real results.</p>
            <span class="service-card-link">
              Explore
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>

        <a href="/trt/" class="service-card group" style="--card-img: url('/images/trt.png')">
          <div class="service-card-bg"></div>
          <div class="service-card-content">
            <span class="service-card-number">03</span>
            <h3 class="service-card-title">TRT<br/>Evaluation</h3>
            <p class="service-card-desc">Lab-driven testosterone assessment with honest evaluation. Focused on your health, not a sales pitch.</p>
            <span class="service-card-link">
              Explore
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>

        <a href="/sleep/" class="service-card group" style="--card-img: url('/images/sleep.jpg')">
          <div class="service-card-bg"></div>
          <div class="service-card-content">
            <span class="service-card-number">04</span>
            <h3 class="service-card-title">Sleep<br/>Issues</h3>
            <p class="service-card-desc">Restless nights running your days? We'll find what's behind it and build a plan that actually works.</p>
            <span class="service-card-link">
              Explore
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- TRT — Full-bleed parallax cinematic          -->
  <!-- ============================================ -->
  <section class="parallax-section" id="trt-parallax">
    <div class="parallax-bg" style="background-image: url('/images/trt-photo.jpg')"></div>
    <div class="parallax-overlay"></div>
    <div class="parallax-content">
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
        <div class="reveal max-w-2xl">
          <span class="label text-accent block mb-5">TRT Evaluation</span>
          <h2 class="font-display font-light text-[clamp(2.5rem,6vw,5rem)] leading-[1.05] tracking-[-0.02em] text-white mb-8">
            Can't push it like<br />
            you <em class="text-accent italic">used to</em>?
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mb-6 max-w-[520px]">
            It's not just in your head. Most men start to see testosterone decline after 30 — less energy, slower recovery, lower drive.
          </p>
          <p class="text-white/60 text-base leading-relaxed mb-10 max-w-[520px]">
            We start with your symptoms and labs for a clear, honest picture. If TRT is the right fit, we build a plan around you. If not, we'll tell you that too.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/trt/" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-white/10 text-white border border-white/30 px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent hover:text-bg transition-all duration-300 backdrop-blur-sm">
              Learn More
            </a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-accent text-bg border border-accent px-7 py-3 rounded-[4px] hover:bg-primary hover:border-primary transition-all duration-300">
              Book a Visit
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- HOW IT WORKS — Numbered vertical timeline    -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-20 text-center">
        <span class="label text-accent block mb-5">How It Works</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text">
          Three steps to <em class="text-accent italic">better</em> care
        </h2>
      </div>

      <div class="grid lg:grid-cols-3 gap-0">
        <!-- Step 1 -->
        <div class="reveal reveal-delay-1 timeline-step group">
          <div class="timeline-number">01</div>
          <div class="timeline-line"></div>
          <h3 class="font-display font-light text-2xl text-text mb-3 mt-8 group-hover:text-accent transition-colors duration-300">Book Online</h3>
          <p class="text-text/50 text-sm leading-relaxed max-w-[280px]">Pick a time that works for you through our secure portal. Same-week availability, evening appointments included.</p>
        </div>
        <!-- Step 2 -->
        <div class="reveal reveal-delay-2 timeline-step group">
          <div class="timeline-number">02</div>
          <div class="timeline-line"></div>
          <h3 class="font-display font-light text-2xl text-text mb-3 mt-8 group-hover:text-accent transition-colors duration-300">Meet Your Provider</h3>
          <p class="text-text/50 text-sm leading-relaxed max-w-[280px]">Connect via secure telehealth from anywhere in Florida. No waiting room, no commute — just real conversation.</p>
        </div>
        <!-- Step 3 -->
        <div class="reveal reveal-delay-3 timeline-step group">
          <div class="timeline-number">03</div>
          <div class="timeline-line"></div>
          <h3 class="font-display font-light text-2xl text-text mb-3 mt-8 group-hover:text-accent transition-colors duration-300">Get Your Plan</h3>
          <p class="text-text/50 text-sm leading-relaxed max-w-[280px]">Walk away with a clear, personalized care plan. Ongoing support, medication management, and follow-ups built in.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SLEEP — Full-bleed cinematic (reversed)      -->
  <!-- ============================================ -->
  <section class="parallax-section" id="sleep-parallax">
    <div class="parallax-bg" style="background-image: url('/images/sleep.jpg')"></div>
    <div class="parallax-overlay"></div>
    <div class="parallax-content">
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 flex justify-end">
        <div class="reveal max-w-2xl text-right">
          <span class="label text-accent block mb-5">Sleep Issues</span>
          <h2 class="font-display font-light text-[clamp(2.5rem,6vw,5rem)] leading-[1.05] tracking-[-0.02em] text-white mb-8">
            Struggling to sleep?<br />
            Crashing through <em class="text-accent italic">your day</em>?
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mb-6 max-w-[520px] ml-auto">
            When restless nights start running your days, it affects your focus, your mood, and your health. You don't have to push through it alone.
          </p>
          <p class="text-white/60 text-base leading-relaxed mb-10 max-w-[520px] ml-auto">
            We'll find what's behind your sleep issues and build a plan that actually helps — real care from a provider who listens.
          </p>
          <div class="flex flex-wrap gap-4 justify-end">
            <a href="/sleep/" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-white/10 text-white border border-white/30 px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent hover:text-bg transition-all duration-300 backdrop-blur-sm">
              Learn More
            </a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-accent text-bg border border-accent px-7 py-3 rounded-[4px] hover:bg-primary hover:border-primary transition-all duration-300">
              Book a Visit
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- STATS — Animated counters                    -->
  <!-- ============================================ -->
  <section class="py-24 sm:py-32 border-t border-b border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid grid-cols-2 lg:grid-cols-4 gap-8 lg:divide-x lg:divide-border">
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2"><span class="counter" data-target="12">0</span>+</p>
          <p class="label text-text-muted">Years Military Service</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-accent mb-2"><span class="counter" data-target="64">0</span>+</p>
          <p class="label text-text-muted">Years Combined Experience</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-accent mb-2">FL</p>
          <p class="label text-text-muted">Statewide Telehealth</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">Late</p>
          <p class="label text-text-muted">Evening Appointments</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- TESTIMONIALS — Overlapping card gallery      -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Real Results</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text max-w-2xl">
          What our patients<br />
          are <em class="text-accent italic">saying</em>
        </h2>
      </div>

      <div class="testimonial-scroll">
        <div class="testimonial-track">
          <div class="testimonial-card reveal reveal-delay-1">
            <img src="/images/testimonial-primary.png" alt="Primary Care testimonial" class="w-full h-auto rounded-xl" />
          </div>
          <div class="testimonial-card reveal reveal-delay-2">
            <img src="/images/testimonial-weightloss.png" alt="Weight Loss testimonial" class="w-full h-auto rounded-xl" />
          </div>
          <div class="testimonial-card reveal reveal-delay-3">
            <img src="/images/testimonial-trt.png" alt="TRT testimonial" class="w-full h-auto rounded-xl" />
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- TEAM — Circle portraits with hover glow      -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">Your Care Team</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text max-w-2xl">
          The providers behind<br />
          your <em class="text-accent italic">care</em>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <div class="reveal reveal-delay-1 text-center group">
          <div class="team-avatar">
            <img src="/images/david.png" alt="David, PA-C" class="w-full h-full object-cover" />
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1 group-hover:text-accent transition-colors duration-300">David, PA-C</h3>
          <p class="label text-primary mb-2">Founder & Primary Provider</p>
          <p class="text-text/40 text-xs">12 years U.S. Army · Licensed FL</p>
        </div>
        <div class="reveal reveal-delay-2 text-center group">
          <div class="team-avatar team-avatar-placeholder">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1 group-hover:text-accent transition-colors duration-300">Julie Vera Rivas</h3>
          <p class="label text-accent mb-2">MSN, APRN, AANP-C</p>
          <p class="text-text/40 text-xs">Nurse Practitioner</p>
        </div>
        <div class="reveal reveal-delay-3 text-center group">
          <div class="team-avatar team-avatar-placeholder">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1 group-hover:text-accent transition-colors duration-300">Dr. Eric Folkens</h3>
          <p class="label text-accent mb-2">Supervising Physician</p>
          <p class="text-text/40 text-xs">ABFM Certified · 34+ years</p>
        </div>
        <div class="reveal reveal-delay-4 text-center group">
          <div class="team-avatar team-avatar-placeholder">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1 group-hover:text-accent transition-colors duration-300">Dr. Mark Dawson</h3>
          <p class="label text-accent mb-2">Supervising Physician</p>
          <p class="text-text/40 text-xs">30+ years gastroenterology</p>
        </div>
      </div>

      <div class="reveal text-center mt-12">
        <a href="/about/" class="inline-flex items-center gap-3 label text-primary hover:text-accent hover:gap-5 transition-all duration-300">
          Meet the full team
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- CTA — Cinematic final push                   -->
  <!-- ============================================ -->
  <section class="py-36 sm:py-44 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-bg to-accent/5"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full border border-border/30 opacity-30"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full border border-accent/10 opacity-20"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Ready to start<br />
          your <em class="text-accent italic">journey</em>?
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit and connect with a provider who takes the time to understand your health. Same-week telehealth, no insurance needed, statewide across Florida.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-accent text-bg border border-accent px-9 py-4 rounded-[4px] hover:bg-primary hover:border-primary transition-all duration-300 text-sm">
            Book a Free Consultation
          </a>
          <a href="/contact/" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-transparent text-text border border-text/30 px-9 py-4 rounded-[4px] hover:border-accent hover:text-accent transition-all duration-300 text-sm">
            Ask a Question
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>


<!-- ============================================ -->
