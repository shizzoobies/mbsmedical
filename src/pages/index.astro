---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="MBS Medical — Telehealth primary care, weight loss, and TRT evaluation across Florida. Cash pay, same-week appointments, one consistent provider.">

  <!-- ============================================ -->
  <!-- HERO — Full viewport, left-aligned text      -->
  <!-- ============================================ -->
  <section class="relative h-screen min-h-[700px] flex items-end overflow-hidden">
    <!-- Video Background -->
    <video
      id="hero-video"
      autoplay
      muted
      playsinline
      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[3000ms]"
      style="object-position: 70% 60%;"
    >
      <source src="/images/flag-intro.mp4" type="video/mp4" />
    </video>

    <!-- Overlay — darkens after video pauses -->
    <div id="hero-overlay" class="absolute inset-0 hero-overlay transition-all duration-[3000ms]"></div>

    <!-- Content — right aligned, bottom portion -->
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 pb-28 sm:pb-36 w-full flex flex-col items-end text-right">
      <h1 class="font-display font-light text-[clamp(3rem,8vw,6.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8 max-w-4xl">
        Medical care<br />
        that <em class="text-accent italic">starts</em><br />
        with you
      </h1>
      <p class="text-text/70 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10 ml-auto">
        Direct access to a licensed provider who knows your history, your goals, and your health. Cash pay, no insurance, same-week appointments across Florida.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300"
        >
          Book a Visit
        </a>
        <a
          href="/services/"
          class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-transparent text-text border border-text/30 px-7 py-3 rounded-[4px] hover:border-accent hover:text-accent transition-all duration-300"
        >
          View Our Services
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce-slow">
      <svg class="w-5 h-5 text-text/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SCROLLING SERVICES MARQUEE                   -->
  <!-- ============================================ -->
  <section class="py-6 border-t border-b border-border overflow-hidden">
    <div class="marquee-container">
      <div class="marquee-track">
        {[1,2].map(() => (
          <Fragment>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Primary Care</span>
            </a>
            <a href="/weight-loss/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Weight Loss</span>
            </a>
            <a href="/trt/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">TRT Evaluation</span>
            </a>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Chronic Conditions</span>
            </a>
            <a href="/weight-loss/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">GLP-1 Evaluation</span>
            </a>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Medication Management</span>
            </a>
            <a href="/trt/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Lab-Driven Assessment</span>
            </a>
            <a href="/sleep/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Sleep Issues</span>
            </a>
          </Fragment>
        ))}
      </div>
    </div>
  </section>

  <style>
    .marquee-container {
      width: 100%;
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
    .marquee-track {
      display: flex;
      width: max-content;
      animation: marquee 35s linear infinite;
    }
    .marquee-track:hover {
      animation-play-state: paused;
    }
    .marquee-item {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 0 32px;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>


  <!-- ============================================ -->
  <!-- SERVICES — Horizontal blocks, alternating    -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <!-- Service 1: Primary Care -->
      <a href="/primary-care/" class="reveal group block py-12 lg:py-16 border-t border-border">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div>
            <h3 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Primary Care</h3>
            <p class="text-text/50 text-base leading-relaxed mb-5 max-w-[480px]">Ongoing care from a provider who knows your history, your medications, and your goals. Routine visits, chronic condition management, and medication oversight.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              View Service
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="aspect-[16/10] rounded-2xl overflow-hidden">
            <img src="/images/primary-care.png" alt="Primary Care" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

      <!-- Service 2: Weight Loss (reversed) -->
      <a href="/weight-loss/" class="reveal group block py-12 lg:py-16 border-t border-border">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="lg:order-2">
            <h3 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Weight Loss</h3>
            <p class="text-text/50 text-base leading-relaxed mb-5 max-w-[480px]">Clinically supervised weight management with GLP-1 receptor agonist evaluation. Personalized plans built around your health history and goals.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              View Service
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="aspect-[16/10] rounded-2xl overflow-hidden lg:order-1">
            <img src="/images/weight-loss.png" alt="Weight Loss" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

      <!-- Service 3: TRT -->
      <a href="/trt/" class="reveal group block py-12 lg:py-16 border-t border-b border-border">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div>
            <h3 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">TRT Evaluation</h3>
            <p class="text-text/50 text-base leading-relaxed mb-5 max-w-[480px]">Lab-driven testosterone assessment with an honest, evaluation-first approach. We start with your symptoms and labs — not a sales pitch.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              View Service
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="aspect-[16/10] rounded-2xl overflow-hidden">
            <img src="/images/trt-photo.jpg" alt="TRT Evaluation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- TRT — Featured callout                       -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div>
          <span class="label text-primary block mb-5">TRT Evaluation</span>
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text mb-6">
            Can't push it like<br />
            you <em class="text-primary italic">used to</em>?
          </h2>
          <p class="text-text/50 text-base leading-relaxed mb-6 max-w-[480px]">
            It's not just in your head. Most men start to see testosterone decline after 30 — less energy, slower recovery, lower drive, and a general feeling that something's off.
          </p>
          <p class="text-text/50 text-base leading-relaxed mb-8 max-w-[480px]">
            We start with your symptoms and labs to get a clear, honest picture. If TRT is the right fit, we'll build a plan around you. If it's not, we'll tell you that too.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/trt/" class="inline-flex items-center gap-3 label text-primary hover:text-accent hover:gap-5 transition-all duration-300">
              Learn More
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300">
              Book a Visit
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="/images/trt-photo.jpg" alt="TRT Evaluation" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SLEEP ISSUES — Featured callout              -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="/images/sleep.jpg" alt="Struggling with sleep" class="w-full h-full object-cover" />
        </div>
        <div>
          <span class="label text-accent block mb-5">Sleep Issues</span>
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text mb-6">
            Struggling to sleep?<br />
            Crashing through <em class="text-accent italic">your day</em>?
          </h2>
          <p class="text-text/50 text-base leading-relaxed mb-6 max-w-[480px]">
            When restless nights start running your days, it's more than just being tired — it affects your focus, your mood, and your health. You don't have to push through it alone.
          </p>
          <p class="text-text/50 text-base leading-relaxed mb-8 max-w-[480px]">
            We'll work with you to understand what's behind your sleep issues and build a plan that actually helps — no cookie-cutter solutions, just real care from a provider who listens.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/sleep/" class="inline-flex items-center gap-3 label text-accent hover:gap-5 transition-all duration-300">
              Learn More
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300">
              Book a Visit
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- STATS BAR                                    -->
  <!-- ============================================ -->
  <section class="py-20 sm:py-28 border-t border-b border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid grid-cols-2 lg:grid-cols-4 gap-8 lg:divide-x lg:divide-border">
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">12+</p>
          <p class="label text-text-muted">Years Military Service</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-accent mb-2">64+</p>
          <p class="label text-text-muted">Years Combined Experience</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-accent mb-2">FL</p>
          <p class="label text-text-muted">Statewide Telehealth</p>
        </div>
        <div class="text-center lg:px-8">
          <p class="font-display font-light text-5xl sm:text-6xl text-primary mb-2">$0</p>
          <p class="label text-text-muted">Insurance Hassle</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- TEAM — Side-by-side portraits                -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">Your Care Team</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text max-w-2xl">
          The providers behind<br />
          your <em class="text-accent italic">care</em>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <!-- David -->
        <div class="reveal reveal-delay-1 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border">
            <img src="/images/david.png" alt="David, PA-C" class="w-full h-full object-cover" />
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">David, PA-C</h3>
          <p class="label text-primary mb-2">Founder & Primary Provider</p>
          <p class="text-text/40 text-xs">12 years U.S. Army &middot; Licensed FL</p>
        </div>
        <!-- Julie -->
        <div class="reveal reveal-delay-2 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border bg-surface-light flex items-center justify-center">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">Julie Vera Rivas</h3>
          <p class="label text-accent mb-2">MSN, APRN, AANP-C</p>
          <p class="text-text/40 text-xs">Nurse Practitioner</p>
        </div>
        <!-- Dr. Folkens -->
        <div class="reveal reveal-delay-3 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border bg-surface-light flex items-center justify-center">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">Dr. Eric Folkens</h3>
          <p class="label text-accent mb-2">Supervising Physician</p>
          <p class="text-text/40 text-xs">ABFM Certified &middot; 34+ years</p>
        </div>
        <!-- Dr. Dawson -->
        <div class="reveal reveal-delay-4 text-center">
          <div class="w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden border-2 border-border bg-surface-light flex items-center justify-center">
            <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-1">Dr. Mark Dawson</h3>
          <p class="label text-accent mb-2">Supervising Physician</p>
          <p class="text-text/40 text-xs">30+ years gastroenterology</p>
        </div>
      </div>

      <div class="reveal text-center mt-12">
        <a href="/about/" class="inline-flex items-center gap-3 label text-primary hover:text-accent hover:gap-5 transition-all duration-300">
          Meet the full team
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

    </div>
  </section>


  <!-- ============================================ -->
  <!-- CTA — Split layout with border accent        -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div class="border-l-[3px] border-primary pl-8 sm:pl-10">
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text">
            Ready to start<br />
            your <em class="text-accent italic">journey</em>?
          </h2>
        </div>

        <div>
          <p class="text-text/50 text-base leading-relaxed mb-8 max-w-[480px]">
            Book a visit and connect with a provider who takes the time to understand your health. Same-week telehealth appointments, no insurance needed, statewide across Florida.
          </p>
          <a
            href="https://mbsmedical.practicebetter.io"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300"
          >
            Book a Free Consultation
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>

<!-- Scroll reveal + video pause -->
<script>
  // Scroll reveals
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Pause video after 10 seconds and darken overlay
  const video = document.getElementById('hero-video');
  const overlay = document.getElementById('hero-overlay');

  if (video) {
    setTimeout(() => {
      video.pause();
      if (overlay) {
        overlay.style.background = 'rgba(8, 8, 8, 0.55)';
      }
    }, 10000);
  }
</script>
