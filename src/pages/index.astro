---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Home" description="MBS Medical — Mind, Body & Spirit. Veteran-owned telehealth providing primary care, weight loss, and TRT evaluation across Florida. Cash pay, same-week appointments.">

  <!-- ============================================ -->
  <!-- HERO — Full viewport, right-aligned text     -->
  <!-- ============================================ -->
  <section class="relative h-screen min-h-[700px] flex items-end overflow-hidden">
    <video
      id="hero-video"
      autoplay
      muted
      playsinline
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[3000ms] hero-video"
    >
      <source src="/images/flag-intro.mp4" type="video/mp4" />
    </video>
    <div id="hero-overlay" class="absolute inset-0 hero-overlay transition-all duration-[3000ms]"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 pb-28 sm:pb-36 w-full flex flex-col items-end text-right">
      <h1 class="font-display font-light text-[clamp(3rem,8vw,6.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8 max-w-4xl">
        Mind, Body<br />
        &amp; <em class="text-accent italic">Spirit</em>
      </h1>
      <p class="text-text/70 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10 ml-auto">
        Veteran-owned telehealth built on the belief that real healthcare treats the whole person. One consistent provider who knows your history, your goals, and your life. Cash pay, no insurance needed, same-week appointments across Florida.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">
          Book a Visit
        </a>
        <a href="/services/" class="btn-pill btn-outline">
          View Our Services
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce-slow">
      <svg class="w-5 h-5 text-text/30" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SCROLLING SERVICES MARQUEE                   -->
  <!-- ============================================ -->
  <section class="py-6 border-t border-b border-border overflow-hidden">
    <div class="marquee-container">
      <div class="marquee-track">
        {[1,2].map(() => (
          <Fragment>
            <a href="/primary-care/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Primary Care</span>
            </a>
            <a href="/weight-loss/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Weight Loss</span>
            </a>
            <a href="/trt/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">TRT Evaluation</span>
            </a>
            <a href="/erectile-dysfunction/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Erectile Dysfunction</span>
            </a>
            <a href="/hair-loss/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Hair Loss</span>
            </a>
            <a href="/birth-control/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Birth Control</span>
            </a>
            <a href="/uti-treatment/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">UTI Treatment</span>
            </a>
            <a href="/menopause/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Menopause</span>
            </a>
            <a href="/anxiety/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Anxiety</span>
            </a>
            <a href="/depression/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Depression</span>
            </a>
            <a href="/adhd/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">ADHD</span>
            </a>
            <a href="/acne/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Acne</span>
            </a>
            <a href="/eczema/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Eczema</span>
            </a>
            <a href="/rosacea/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Rosacea</span>
            </a>
            <a href="/sleep/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Sleep Issues</span>
            </a>
            <a href="/cold-flu/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Cold & Flu</span>
            </a>
            <a href="/sinus-infections/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Sinus Infections</span>
            </a>
            <a href="/allergies/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Allergies</span>
            </a>
            <a href="/pink-eye/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Pink Eye</span>
            </a>
            <a href="/diabetes/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Diabetes</span>
            </a>
            <a href="/cholesterol/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Cholesterol</span>
            </a>
            <a href="/thyroid/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Thyroid</span>
            </a>
            <a href="/smoking-cessation/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Smoking Cessation</span>
            </a>
            <a href="/sexual-health/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">Sexual Health</span>
            </a>
            <a href="/gerd/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">GERD</span>
            </a>
            <a href="/ibs/" class="marquee-item group">
              <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span>
              <span class="font-display font-light text-2xl sm:text-3xl text-text/60 group-hover:text-accent transition-colors duration-300 whitespace-nowrap">IBS</span>
            </a>
          </Fragment>
        ))}
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SERVICES — Hims-style mixed card grid        -->
  <!-- ============================================ -->
  <section class="py-20 sm:py-28">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <!-- Top row: 2 large feature cards -->
      <div class="grid lg:grid-cols-2 gap-5 mb-5">

        <!-- Weight Loss — hero card -->
        <a href="/weight-loss/" class="hims-card hims-card-tall group relative overflow-hidden" style="background: linear-gradient(135deg, #1a2a1a 0%, #0d1a0d 100%);">
          <div class="hims-card-img-wrap">
            <!-- PLACEHOLDER: lifestyle image of someone healthy/active, warm tones, cropped to right side -->
            <img src="/images/weight-loss.png" alt="Weight loss program" class="hims-card-img" />
          </div>
          <div class="relative z-10 flex flex-col h-full justify-between p-8 sm:p-10">
            <div>
              <span class="inline-block bg-accent/20 text-accent text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-6">GLP-1 Available</span>
              <h3 class="font-display font-light text-[clamp(2rem,4vw,3rem)] leading-[1.1] text-white mb-3 group-hover:text-accent transition-colors duration-300">
                Start your weight<br/>loss journey
              </h3>
              <p class="text-white/50 text-sm leading-relaxed max-w-[320px]">Clinically supervised plans with GLP-1 evaluation. Real results, not promises.</p>
            </div>
            <span class="inline-flex items-center gap-2 text-accent text-xs font-bold uppercase tracking-widest mt-6 group-hover:gap-4 transition-all duration-300">
              Get Started <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <!-- TRT — hero card -->
        <a href="/trt/" class="hims-card hims-card-tall group relative overflow-hidden" style="background: linear-gradient(135deg, #2a1a1a 0%, #1a0d0d 100%);">
          <div class="hims-card-img-wrap">
            <!-- PLACEHOLDER: masculine lifestyle image, maybe someone working out or confident pose -->
            <img src="/images/trt.png" alt="TRT evaluation" class="hims-card-img" />
          </div>
          <div class="relative z-10 flex flex-col h-full justify-between p-8 sm:p-10">
            <div>
              <span class="inline-block bg-primary/20 text-primary text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-6">Lab-Driven</span>
              <h3 class="font-display font-light text-[clamp(2rem,4vw,3rem)] leading-[1.1] text-white mb-3 group-hover:text-accent transition-colors duration-300">
                Get your edge<br/>back with TRT
              </h3>
              <p class="text-white/50 text-sm leading-relaxed max-w-[320px]">Honest testosterone evaluation. If it's right for you, we'll build a plan. If not, we'll tell you.</p>
            </div>
            <span class="inline-flex items-center gap-2 text-primary text-xs font-bold uppercase tracking-widest mt-6 group-hover:gap-4 group-hover:text-accent transition-all duration-300">
              Learn More <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      </div>

      <!-- Bottom row: 3 smaller cards -->
      <div class="grid sm:grid-cols-3 gap-5">

        <!-- Primary Care -->
        <a href="/primary-care/" class="hims-card hims-card-compact group" style="background: #141e14;">
          <div class="p-7 flex flex-col h-full justify-between">
            <div>
              <h3 class="font-display font-light text-2xl text-white mb-2 group-hover:text-accent transition-colors duration-300">Primary Care</h3>
              <p class="text-white/40 text-sm leading-relaxed">Ongoing care from a provider who knows your history.</p>
            </div>
            <div class="flex items-center justify-between mt-6">
              <span class="text-accent text-xs font-bold uppercase tracking-widest group-hover:translate-x-1 transition-transform duration-300">Explore →</span>
              <!-- PLACEHOLDER: small icon or product image, stethoscope or medical symbol -->
              <div class="w-16 h-16 rounded-2xl overflow-hidden opacity-60 group-hover:opacity-100 transition-opacity duration-300">
                <img src="/images/primary-care.png" alt="Primary care consultation" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </a>

        <!-- Sleep Issues -->
        <a href="/sleep/" class="hims-card hims-card-compact group" style="background: #1a1428;">
          <div class="p-7 flex flex-col h-full justify-between">
            <div>
              <h3 class="font-display font-light text-2xl text-white mb-2 group-hover:text-accent transition-colors duration-300">Sleep Issues</h3>
              <p class="text-white/40 text-sm leading-relaxed">Restless nights running your days? We'll figure it out.</p>
            </div>
            <div class="flex items-center justify-between mt-6">
              <span class="text-accent text-xs font-bold uppercase tracking-widest group-hover:translate-x-1 transition-transform duration-300">Explore →</span>
              <div class="w-16 h-16 rounded-2xl overflow-hidden opacity-60 group-hover:opacity-100 transition-opacity duration-300">
                <img src="/images/sleep.jpg" alt="Sleep health treatment" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </a>

        <!-- Chronic Conditions -->
        <a href="/primary-care/" class="hims-card hims-card-compact group" style="background: #1e1a14;">
          <div class="p-7 flex flex-col h-full justify-between">
            <div>
              <h3 class="font-display font-light text-2xl text-white mb-2 group-hover:text-accent transition-colors duration-300">Chronic Conditions</h3>
              <p class="text-white/40 text-sm leading-relaxed">Medication management and ongoing condition oversight.</p>
            </div>
            <div class="flex items-center justify-between mt-6">
              <span class="text-accent text-xs font-bold uppercase tracking-widest group-hover:translate-x-1 transition-transform duration-300">Explore →</span>
              <!-- PLACEHOLDER: medical/clipboard/vitals icon image -->
              <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center opacity-60 group-hover:opacity-100 transition-opacity duration-300">
                <svg class="w-8 h-8 text-primary" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- WEIGHT LOSS FEATURE — Dark cinematic section -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36" style="background: linear-gradient(160deg, #1a0f0a 0%, #0c0c0c 40%, #0a0f1a 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.02em] text-text mb-6">
            Your weight loss<br/>
            <em class="text-accent italic">breakthrough</em> is here
          </h2>
          <p class="text-text/50 text-lg leading-relaxed mb-6 max-w-[480px]">
            GLP-1 receptor agonists are changing the game. We evaluate whether they're right for you with real labs, real conversation, and a plan built around your life.
          </p>
          <p class="text-text/50 text-base leading-relaxed mb-10 max-w-[480px]">
            No gimmicks. No one-size-fits-all. Just clinically supervised weight management from a provider who sticks with you.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/weight-loss/" class="btn-pill btn-accent">Learn More</a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          </div>
        </div>
        <div class="relative">
          <!-- PLACEHOLDER: dramatic product/lifestyle shot — could be GLP-1 related, studio lighting, dark bg -->
          <div class="rounded-[24px] overflow-hidden">
            <img src="/images/weight-loss.png" alt="Weight loss program" class="w-full h-auto rounded-[24px]" />
          </div>
          <!-- Floating stat badge -->
          <div class="absolute -bottom-4 -left-4 bg-[#0c0c0c]/90 backdrop-blur-xl border border-accent/30 rounded-2xl px-6 py-4 shadow-xl">
            <p class="font-display text-3xl text-accent mb-0.5">GLP-1</p>
            <p class="text-text/70 text-xs uppercase tracking-widest">Evaluation Available</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- TRT — Warm tinted section                    -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36" style="background: linear-gradient(160deg, #1a1410 0%, #0c0c0c 50%, #141018 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="lg:order-2">
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.02em] text-text mb-6">
            Can't push it like<br/>
            you <em class="text-primary italic">used to</em>?
          </h2>
          <p class="text-text/50 text-lg leading-relaxed mb-6 max-w-[480px]">
            Most men start to see testosterone decline after 30 — less energy, slower recovery, lower drive, and a feeling that something's off.
          </p>
          <p class="text-text/50 text-base leading-relaxed mb-10 max-w-[480px]">
            We start with your symptoms and labs for a clear, honest picture. If TRT is right, we build a plan around you. If not, we'll tell you that too.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/trt/" class="btn-pill btn-outline">Learn More</a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          </div>
        </div>
        <div class="lg:order-1 relative">
          <!-- PLACEHOLDER: masculine lifestyle photo, warm tones, could be someone active/outdoors -->
          <div class="rounded-[24px] overflow-hidden">
            <img src="/images/trt-photo.jpg" alt="TRT evaluation" class="w-full h-auto rounded-[24px]" />
          </div>
          <div class="absolute -top-4 -right-4 bg-[#0c0c0c]/90 backdrop-blur-xl border border-primary/30 rounded-2xl px-6 py-4 shadow-xl">
            <p class="font-display text-3xl text-primary mb-0.5">Lab-Driven</p>
            <p class="text-text/70 text-xs uppercase tracking-widest">Honest Assessment</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SLEEP — Purple-tinted section                -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.02em] text-text mb-6">
            Struggling to sleep?<br/>
            Crashing through <em class="text-accent italic">your day</em>?
          </h2>
          <p class="text-text/50 text-lg leading-relaxed mb-6 max-w-[480px]">
            When restless nights start running your days, it affects everything — focus, mood, health. You don't have to push through it alone.
          </p>
          <p class="text-text/50 text-base leading-relaxed mb-10 max-w-[480px]">
            We'll find what's behind your sleep issues and build a plan that actually works. Real care from a provider who listens.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/sleep/" class="btn-pill btn-accent">Learn More</a>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          </div>
        </div>
        <div class="relative">
          <!-- PLACEHOLDER: moody sleep-related image, someone resting or night-time atmosphere -->
          <div class="rounded-[24px] overflow-hidden">
            <img src="/images/sleep.jpg" alt="Sleep issues treatment" class="w-full h-auto rounded-[24px]" />
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- HOW IT WORKS — Clean 3-column, no numbers    -->
  <!-- ============================================ -->
  <section class="py-28 sm:py-36 relative">
    <AsciiHover />
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 relative z-2">
      <div class="reveal mb-16 text-center">
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text">
          Three steps to <em class="text-accent italic">better</em> care
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="reveal hims-step-card group">
