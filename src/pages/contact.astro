---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with MBS Medical. Send us a message or book a telehealth visit through our secure patient portal.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">Contact</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Get in <em class="text-primary italic">touch</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px]">
          Have a question before booking? Send us a message and we'll get back to you within one business day.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="reveal">
            <h2 class="font-display font-light text-3xl text-text mb-8">Send us a message</h2>
            <form class="space-y-6" id="contact-form">
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="label text-text-muted block mb-2">Full Name</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3.5 rounded-lg bg-surface-light border border-border text-text placeholder-text-muted/50 focus:outline-none focus:border-primary transition-colors" placeholder="Your name" />
                </div>
                <div>
                  <label for="email" class="label text-text-muted block mb-2">Email</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3.5 rounded-lg bg-surface-light border border-border text-text placeholder-text-muted/50 focus:outline-none focus:border-primary transition-colors" placeholder="you@email.com" />
                </div>
              </div>
              <div>
                <label for="phone" class="label text-text-muted block mb-2">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3.5 rounded-lg bg-surface-light border border-border text-text placeholder-text-muted/50 focus:outline-none focus:border-primary transition-colors" placeholder="(555) 123-4567" />
              </div>
              <div>
                <label for="topic" class="label text-text-muted block mb-2">Topic</label>
                <select id="topic" name="topic" class="w-full px-4 py-3.5 rounded-lg bg-surface-light border border-border text-text focus:outline-none focus:border-primary transition-colors">
                  <option value="">Select a topic</option>
                  <option value="primary-care">Primary Care</option>
                  <option value="weight-loss">Weight Loss</option>
                  <option value="trt">TRT Evaluation</option>
                  <option value="billing">Billing Question</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="label text-text-muted block mb-2">Message</label>
                <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3.5 rounded-lg bg-surface-light border border-border text-text placeholder-text-muted/50 focus:outline-none focus:border-primary transition-colors resize-none" placeholder="How can we help?"></textarea>
              </div>
              <button type="submit" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300">
                Send Message
              </button>
            </form>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Book -->
          <div class="reveal border border-primary/30 rounded-2xl p-8">
            <h3 class="font-display font-light text-2xl text-text mb-3">Ready to book?</h3>
            <p class="text-text/40 text-sm leading-relaxed mb-6">Skip the form and schedule directly through our secure patient portal.</p>
            <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-5 py-2.5 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300">
              Book a Visit
            </a>
          </div>

          <!-- Info -->
          <div class="reveal reveal-delay-1 border border-border rounded-2xl p-8">
            <h3 class="font-display font-light text-2xl text-text mb-6">Practice info</h3>
            <div class="space-y-5">
              <div>
                <p class="label text-text-muted mb-1">Hours</p>
                <p class="text-text text-base">Mon &ndash; Fri, 8:00 AM &ndash; 6:00 PM</p>
              </div>
              <div>
                <p class="label text-text-muted mb-1">Delivery</p>
                <p class="text-text text-base">Telehealth only &middot; Statewide Florida</p>
              </div>
              <div>
                <p class="label text-text-muted mb-1">Payment</p>
                <p class="text-text text-base">Cash pay &middot; No insurance needed</p>
              </div>
            </div>
          </div>

          <!-- Emergency -->
          <div class="reveal reveal-delay-2 border border-red-500/20 rounded-2xl p-6">
            <p class="text-red-400 text-sm font-medium mb-1">Medical Emergency?</p>
            <p class="text-red-400/60 text-xs leading-relaxed">Call 911 or go to the nearest emergency room. This practice does not provide emergency services.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

</Layout>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
