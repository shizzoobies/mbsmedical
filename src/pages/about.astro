---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'David, PA-C',
    role: 'Founder & Primary Provider',
    label: 'primary',
    image: '/images/david.png',
    bio: 'Physician Associate with 12 years of U.S. Army service. Licensed in Florida. Specializes in primary care, weight loss, and TRT evaluation. Founded MBS Medical to provide direct, consistent access to a provider who knows each patient\'s full health picture.',
    tags: ['PA-C, Licensed FL', '12 Years U.S. Army', 'Primary Care', 'Weight Loss', 'TRT Evaluation'],
  },
  {
    name: 'Julie Vera Rivas',
    role: 'MSN, APRN, AANP-C',
    label: 'accent',
    image: null,
    bio: 'Board-certified Nurse Practitioner bringing advanced clinical expertise to the MBS Medical team. Focused on delivering compassionate, patient-centered telehealth care across Florida.',
    tags: ['MSN', 'APRN', 'AANP-C'],
  },
  {
    name: 'Dr. Eric Folkens, MD',
    role: 'Supervising Physician',
    label: 'accent',
    image: null,
    bio: 'American Board of Family Medicine certified with 34+ years of clinical practice in family medicine and primary care.',
    tags: ['ABFM Certified', '34+ Years', 'Family Medicine'],
  },
  {
    name: 'Dr. Mark Dawson, MD',
    role: 'Supervising Physician',
    label: 'accent',
    image: null,
    bio: '30+ years clinical practice specializing in gastroenterology and metabolic health. Provides oversight for cases involving GI health and complex comorbidities.',
    tags: ['30+ Years', 'Gastroenterology', 'Metabolic Health'],
  },
];
---

<Layout title="About" description="Meet the MBS Medical team — providers with decades of combined clinical experience delivering telehealth across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">About Us</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Built on <em class="text-primary italic">relationships</em>,<br />not appointments
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px]">
          MBS Medical was founded on a simple idea: healthcare works better when your provider actually knows you. One consistent provider, comprehensive records, and a care plan that evolves with your life.
        </p>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
        <div class="reveal border border-border rounded-2xl p-8">
          <span class="font-display font-light text-3xl text-primary block mb-4">Continuity of care</span>
          <p class="text-text/50 text-base leading-relaxed">You see the same provider every time. They know your history, your medications, and your goals — not just what's in the chart.</p>
        </div>
        <div class="reveal reveal-delay-1 border border-border rounded-2xl p-8">
          <span class="font-display font-light text-3xl text-primary block mb-4">Evolving care plans</span>
          <p class="text-text/50 text-base leading-relaxed">Your care plan isn't static. It grows and adapts as your health changes, your goals shift, and new information comes in.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <div class="reveal mb-20">
        <span class="label text-primary block mb-5">The Team</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Who's behind your <em class="text-primary italic">care</em></h2>
      </div>

      <div class="space-y-16">
        {team.map((member, i) => (
          <div class:list={['reveal', i > 0 && 'reveal-delay-1', 'grid lg:grid-cols-12 gap-8 lg:gap-12 items-center', i < team.length - 1 && 'pb-16 border-b border-border']}>
            <!-- Photo -->
            <div class="lg:col-span-3 flex justify-center lg:justify-start">
              <div class="w-40 h-40 sm:w-48 sm:h-48 rounded-full overflow-hidden border-2 border-border shrink-0">
                {member.image ? (
                  <img src={member.image} alt={member.name} class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full bg-surface-light flex items-center justify-center">
                    <svg class="w-16 h-16 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  </div>
                )}
              </div>
            </div>
            <!-- Info -->
            <div class="lg:col-span-9">
              <p class:list={['label mb-2', member.label === 'primary' ? 'text-primary' : 'text-accent']}>{member.role}</p>
              <h3 class="font-display font-light text-3xl sm:text-4xl text-text mb-4">{member.name}</h3>
              <p class="text-text/50 text-base leading-relaxed mb-6 max-w-[540px]">{member.bio}</p>
              <div class="flex flex-wrap gap-2">
                {member.tags.map((tag) => (
                  <span class="font-ui text-[10px] font-semibold uppercase tracking-[0.12em] px-4 py-2 rounded-[4px] border border-border text-text/50">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="border-l-[3px] border-primary pl-8 sm:pl-10">
          <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Ready to meet<br />your <em class="text-primary italic">provider</em>?</h2>
        </div>
        <div>
          <p class="text-text/50 text-base leading-relaxed mb-8 max-w-[480px]">Book a visit and start building a care relationship that lasts.</p>
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-7 py-3 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300">Book a Visit</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
