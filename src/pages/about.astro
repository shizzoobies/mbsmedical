---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';

const team = [
  {
    name: 'David Hervig, PA-C',
    role: 'Founder & Primary Provider',
    label: 'primary',
    image: '/images/david.png',
    bio: 'Physician Associate with 12 years of U.S. Army service. Licensed in Florida. Specializes in primary care, weight loss, and TRT evaluation. Founded MBS Medical to provide direct, consistent access to a provider who knows each patient\'s full health picture.',
    shortBio: 'Physician Associate with 12 years of U.S. Army service. Founded MBS Medical to provide direct, consistent access to care.',
    tags: ['PA-C, Licensed FL', '12 Years U.S. Army', 'Primary Care', 'Weight Loss', 'TRT Evaluation'],
  },
  {
    name: 'Julie Vera Rivas, MSN, APRN, FNP-C',
    role: 'Nurse Practitioner',
    label: 'accent',
    image: '/images/Julie.jpg',
    bio: 'Julie is a board-certified Family Nurse Practitioner specializing in primary care and weight management, with over 27 years of healthcare experience, including 10 years as a Registered Nurse. She takes a comprehensive, patient-centered approach, helping patients achieve sustainable health and metabolic balance.\n\nShe believes lasting transformation begins with understanding the whole person — what works, what doesn\'t, and what can realistically be maintained. Health isn\'t built through extremes, but through consistent, intentional habits that fit seamlessly into everyday life.\n\nCombining primary care expertise with practical, evidence-based strategies, she partners with patients to create personalized care plans that support long-term success. Through education, accountability, and a compassionate, judgment-free approach, she empowers patients to take control of their health and achieve meaningful, lasting results.',
    shortBio: 'Board-certified Family Nurse Practitioner with 27+ years of healthcare experience, specializing in primary care and weight management.',
    tags: ['MSN', 'APRN', 'FNP-C', '27+ Years Healthcare', 'Primary Care', 'Weight Management'],
  },
  {
    name: 'Dr. Eric Folkens, MD',
    role: 'Physician & Consultant',
    label: 'accent',
    image: '/images/folkens.jpg',
    bio: 'Dr. Folkens is an American Board of Family Medicine Certified Diplomate with over 34 years of clinical experience. A family medicine specialist based in Bradenton, Florida, he founded multiple urgent care centers across the Sarasota–Bradenton area and served as Chief Resident during his family medicine residency.\n\nHe is a fellow of the American Academy of Family Physicians and brings deep expertise in primary care, clinical research, and patient-centered medicine. As a consulting physician with MBS Medical, Dr. Folkens provides guidance on complex cases, drawing on decades of hands-on practice across family medicine and urgent care settings.',
    shortBio: 'ABFM Certified Diplomate with 34+ years in family medicine. Founder of multiple urgent care centers across Florida.',
    tags: ['ABFM Certified', '34+ Years', 'Family Medicine', 'AAFP Fellow', 'Clinical Research'],
  },
  {
    name: 'Dr. Mark Dawson, MD',
    role: 'Physician & Consultant',
    label: 'accent',
    image: '/images/dawson.png',
    bio: 'Dr. Dawson is a board-certified internist and gastroenterologist with over 30 years of clinical practice. He completed his medical degree at the University of Illinois College of Medicine, followed by his internship, residency, and fellowship at Cook County Hospital in Chicago.\n\nWith decades of experience spanning private practice and health system settings, Dr. Dawson brings deep expertise in GI health and complex medical conditions. As a consulting physician with MBS Medical, he provides guidance on cases involving gastrointestinal concerns, metabolic health, and multisystem comorbidities.',
    shortBio: 'Board-certified gastroenterologist with 30+ years of clinical practice. University of Illinois College of Medicine.',
    tags: ['30+ Years', 'Gastroenterology', 'Internal Medicine', 'Board Certified'],
  },
];
---

<Layout title="About" description="Meet the MBS Medical team — providers with decades of combined clinical experience delivering telehealth across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #0a0f1a 0%, #080808 50%, #0f1a14 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">About Us</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Built on <em class="text-primary italic">relationships</em>,<br />not appointments
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px]">
          MBS Medical was founded on a simple idea: healthcare works better when your provider actually knows you. One consistent provider, comprehensive records, and a care plan that evolves with your life.
        </p>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
        <div class="reveal bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h2 class="font-display font-light text-3xl text-primary block mb-4">Continuity of care</h2>
          <p class="text-text/50 text-base leading-relaxed">You see the same provider every time. They know your history, your medications, and your goals — not just what's in the chart.</p>
        </div>
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h2 class="font-display font-light text-3xl text-primary block mb-4">Evolving care plans</h2>
          <p class="text-text/50 text-base leading-relaxed">Your care plan isn't static. It grows and adapts as your health changes, your goals shift, and new information comes in.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-28 sm:py-36 border-t border-border" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <div class="reveal mb-20">
        <span class="label text-primary block mb-5">The Team</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Who's behind your <em class="text-primary italic">care</em></h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {team.map((member, i) => (
          <button
            class:list={['reveal team-card group text-left', i > 0 && `reveal-delay-${Math.min(i, 4)}`]}
            data-member={JSON.stringify({ name: member.name, role: member.role, label: member.label, image: member.image, bio: member.bio, tags: member.tags })}
            type="button"
          >
            <!-- Photo -->
            <div class="flex justify-center mb-6">
              <div class="w-28 h-28 sm:w-32 sm:h-32 rounded-full overflow-hidden border-2 border-border group-hover:border-[#3AABA5]/50 transition-all duration-300 shrink-0">
                {member.image ? (
                  <img src={member.image} alt={member.name} class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full bg-surface-light flex items-center justify-center">
                    <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  </div>
                )}
              </div>
            </div>
            <!-- Info -->
            <div class="text-center">
              <p class:list={['label mb-2', member.label === 'primary' ? 'text-primary' : 'text-accent']}>{member.role}</p>
              <h3 class="font-display font-light text-xl sm:text-2xl text-text mb-3 group-hover:text-primary transition-colors duration-300">{member.name}</h3>
              <p class="text-text/40 text-sm leading-relaxed line-clamp-2">{member.shortBio || member.bio}</p>
            </div>
            <!-- Hover hint -->
            <div class="mt-4 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <span class="font-ui text-[10px] font-semibold uppercase tracking-[0.15em] text-primary/60">View profile</span>
            </div>
          </button>
        ))}
      </div>

      <!-- Modal -->
      <div id="team-modal" class="team-modal-overlay" aria-hidden="true">
        <div class="team-modal-backdrop"></div>
        <div class="team-modal-container">
          <div class="team-modal-content">
            <button id="modal-close" class="team-modal-close" type="button" aria-label="Close">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
            <div class="flex flex-col sm:flex-row gap-8 items-center sm:items-start">
              <div id="modal-photo" class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden border-2 border-border shrink-0"></div>
              <div class="flex-1 text-center sm:text-left">
                <p id="modal-role" class="label mb-2"></p>
                <h3 id="modal-name" class="font-display font-light text-3xl sm:text-4xl text-text mb-6"></h3>
                <div id="modal-bio" class="text-text/50 text-base leading-relaxed mb-8 space-y-4"></div>
                <div id="modal-tags" class="flex flex-wrap gap-2 justify-center sm:justify-start"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Ready to meet<br />your <em class="text-primary italic">provider</em>?
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit and start building a care relationship that lasts.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Team Cards */
  .team-card {
    background: #0F0F0F;
    border: 1px solid rgba(237, 233, 224, 0.08);
    border-radius: 24px;
    padding: 2rem 1.5rem 1.5rem;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .team-card:hover {
    border-color: rgba(68, 189, 183, 0.35);
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3), 0 0 40px rgba(68, 189, 183, 0.06);
    background: #121212;
  }
  .team-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Line clamp */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Modal */
  .team-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .team-modal-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .team-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .team-modal-container {
    position: relative;
    width: 90%;
    max-width: 720px;
    max-height: 85vh;
    overflow-y: auto;
    transform: scale(0.95) translateY(10px);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .team-modal-overlay.open .team-modal-container {
    transform: scale(1) translateY(0);
  }
  .team-modal-content {
    background: #111111;
    border: 1px solid rgba(237, 233, 224, 0.1);
    border-radius: 24px;
    padding: 2.5rem;
  }
  .team-modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    color: rgba(237, 233, 224, 0.4);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: color 0.2s ease, background 0.2s ease;
    z-index: 1;
  }
  .team-modal-close:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
  }
</style>
<script>
  // Reveal animations
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Team modal
  const modal = document.getElementById('team-modal');
  const modalClose = document.getElementById('modal-close');
  const modalPhoto = document.getElementById('modal-photo');
  const modalRole = document.getElementById('modal-role');
  const modalName = document.getElementById('modal-name');
  const modalBio = document.getElementById('modal-bio');
  const modalTags = document.getElementById('modal-tags');
  const backdrop = modal?.querySelector('.team-modal-backdrop');

  function openModal(member: { name: string; role: string; label: string; image: string | null; bio: string; tags: string[] }) {
    if (!modal || !modalPhoto || !modalRole || !modalName || !modalBio || !modalTags) return;

    // Photo
    if (member.image) {
      modalPhoto.innerHTML = `<img src="${member.image}" alt="${member.name}" class="w-full h-full object-cover" />`;
    } else {
      modalPhoto.innerHTML = `<div class="w-full h-full bg-surface-light flex items-center justify-center rounded-full"><svg class="w-14 h-14 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg></div>`;
    }

    // Role
    modalRole.className = `label mb-2 ${member.label === 'primary' ? 'text-primary' : 'text-accent'}`;
    modalRole.textContent = member.role;

    // Name
    modalName.textContent = member.name;

    // Bio — split on newlines for paragraphs
    modalBio.innerHTML = member.bio.split('\n').filter((p: string) => p.trim()).map((p: string) => `<p>${p}</p>`).join('');

    // Tags
    modalTags.innerHTML = member.tags.map((tag: string) => `<span class="font-ui text-[10px] font-semibold uppercase tracking-[0.12em] px-4 py-2 rounded-full border border-border text-text/50">${tag}</span>`).join('');

    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Card clicks
  document.querySelectorAll('.team-card').forEach((card) => {
    card.addEventListener('click', () => {
      const data = (card as HTMLElement).dataset.member;
      if (data) openModal(JSON.parse(data));
    });
  });

  // Close handlers
  modalClose?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
