---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="UTI Treatment" description="Same-day telehealth evaluation and treatment for urinary tract infections. No waiting room, no hassle. MBS Medical serves patients across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #14101e 0%, #080808 50%, #1a0f14 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="max-w-xl">
          <span class="label text-accent block mb-5">UTI Treatment</span>
          <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
            Fast UTI relief<br />without the <em class="text-accent italic">wait</em>
          </h1>
          <p class="text-text/50 text-base sm:text-lg leading-relaxed mb-10">
            Same-day telehealth evaluation and treatment for urinary tract infections. No waiting room, no hassle.
          </p>
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
        </div>
        <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center">
          <span class="text-text-muted text-sm">Image Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Help -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">How We Help</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Relief that doesn't make you <em class="text-accent italic">wait</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Rapid Evaluation</h3>
          <p class="text-text/50 text-sm leading-relaxed">A thorough symptom review and clinical assessment via telehealth — so we can determine the right course of action without delay.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Prescription Treatment</h3>
          <p class="text-text/50 text-sm leading-relaxed">Appropriate antibiotics prescribed same-day and sent directly to your pharmacy. No waiting rooms, no unnecessary trips to urgent care.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Follow-Up Care</h3>
          <p class="text-text/50 text-sm leading-relaxed">Monitoring for resolution and recurrent UTI management. If your symptoms persist or keep coming back, we dig deeper to find out why.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 sm:py-36 border-t border-border relative" style="background: linear-gradient(160deg, #1a0f14 0%, #0c0c0c 50%, #14101e 100%);">
    <AsciiHover charset="·∘⊹" cellSize={24} radius={140} baseOpacity={0.03} />
    <div class="relative z-2 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Common Questions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What you need to <em class="text-accent italic">know</em></h2>
      </div>
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl">
        <div class="reveal">
          <h3 class="font-display font-light text-2xl text-text mb-3">Can you treat UTIs via telehealth?</h3>
          <p class="text-text/50 text-base leading-relaxed">Yes. Uncomplicated urinary tract infections are one of the most common conditions treated via telehealth. Based on your symptoms and history, we can diagnose and prescribe treatment without an in-person visit.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <h3 class="font-display font-light text-2xl text-text mb-3">How fast can I get a prescription?</h3>
          <p class="text-text/50 text-base leading-relaxed">In most cases, same-day. Once your telehealth visit is complete and a UTI is confirmed, we send the prescription directly to your pharmacy so you can start treatment right away.</p>
        </div>
        <div class="reveal reveal-delay-2">
          <h3 class="font-display font-light text-2xl text-text mb-3">What if my UTI keeps coming back?</h3>
          <p class="text-text/50 text-base leading-relaxed">Recurrent UTIs require a different approach. We'll evaluate potential contributing factors, consider preventive strategies, and order lab work if needed to identify underlying causes and break the cycle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Get relief<br /><em class="text-accent italic">today</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit and get evaluated by a provider who can prescribe treatment the same day — so you can start feeling better fast.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-accent">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
