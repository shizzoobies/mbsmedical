---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Sexual Health" description="Discreet, judgment-free sexual health evaluation via telehealth. STI screening, treatment, and ongoing wellness from the privacy of home.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #1a0f0a 0%, #080808 50%, #0a0f1a 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-accent block mb-5">Sexual Health</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Sexual health,<br /><em class="text-accent italic">without</em> the awkwardness
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
          Discreet, judgment-free sexual health evaluation via telehealth. STI screening, treatment, and ongoing wellness from the privacy of home.
        </p>
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Our Approach</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Comprehensive care,<br /><em class="text-accent italic">your terms</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">STI Screening</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Lab orders for comprehensive STI panels</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Targeted testing based on risk factors</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Confidential results review with your provider</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Treatment & Management</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Prescription treatment for diagnosed infections</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Follow-up testing to confirm resolution</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Ongoing management for chronic conditions</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Preventive Care</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Risk assessment and education</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> PrEP evaluation and prescribing</li>
            <li class="flex gap-3"><span class="text-accent mt-0.5">&#8226;</span> Partner notification guidance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Placeholder -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal">
        <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center">
          <span class="text-text-muted text-sm">Image Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Get screened with <em class="text-accent italic">confidence</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a private telehealth visit and take charge of your sexual health with a provider who makes it easy.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-accent">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
