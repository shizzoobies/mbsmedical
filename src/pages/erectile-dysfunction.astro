---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Erectile Dysfunction" description="Discreet, clinically supervised ED treatment via telehealth. Licensed provider, real evaluation, personalized plans.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #1a1410 0%, #080808 50%, #141018 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">Erectile Dysfunction</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Take back your<br /><em class="text-primary italic">confidence</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
          Discreet, clinical evaluation and treatment for ED. Real conversation with a licensed provider — no judgment, no gimmicks.
        </p>
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
      </div>
    </div>
  </section>

  <!-- What We Evaluate -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">Clinical Review</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What we <em class="text-primary italic">evaluate</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Medical History Review</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Current medications and supplements</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Existing medical conditions</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Cardiovascular health assessment</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Root Cause Assessment</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Hormonal factors and imbalances</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Vascular and circulatory considerations</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Psychological or medication-related factors</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Treatment Options</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> FDA-approved medications tailored to you</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Lifestyle modifications and guidance</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Ongoing monitoring and adjustments</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-28 sm:py-36 relative" style="background: linear-gradient(160deg, #1a0f0a 0%, #0c0c0c 50%, #0a0f1a 100%);">
    <AsciiHover charset="·×∘" cellSize={24} radius={140} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl mx-auto text-center">
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text mb-8">
          Discreet care,<br />built on <em class="text-accent italic">honesty</em>
        </h2>
        <p class="text-text/40 text-base leading-relaxed mb-12 max-w-[540px] mx-auto">
          ED is more common than most people think — and it deserves a real clinical evaluation, not a checkout page. We listen, assess, and build a plan that makes sense for your health.
        </p>
        <div class="grid sm:grid-cols-3 gap-8 text-left">
          <div class="bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[20px] p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
            <span class="font-display font-light text-3xl text-primary block mb-3">Discreet</span>
            <p class="text-text/40 text-sm leading-relaxed">Private telehealth visits from the comfort of your home.</p>
          </div>
          <div class="bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[20px] p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
            <span class="font-display font-light text-3xl text-primary block mb-3">Honest</span>
            <p class="text-text/40 text-sm leading-relaxed">A real assessment — not a script designed to sell you medication.</p>
          </div>
          <div class="bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[20px] p-8 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
            <span class="font-display font-light text-3xl text-primary block mb-3">Optimized</span>
            <p class="text-text/40 text-sm leading-relaxed">Ongoing follow-ups to refine your treatment over time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">Common Questions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What to <em class="text-primary italic">know</em></h2>
      </div>
      <div class="max-w-3xl space-y-4">
        {[
          { q: 'Is ED treatment available via telehealth?', a: 'Yes. A thorough clinical evaluation, diagnosis, and ongoing management of ED can be handled effectively through telehealth visits with a licensed provider.' },
          { q: 'What medications do you prescribe?', a: 'We prescribe FDA-approved medications based on your specific health profile. Your provider will discuss all options during your evaluation and recommend what\'s most appropriate for you.' },
          { q: 'How discreet is the process?', a: 'Completely. Your visits are conducted privately via telehealth, and your health information is protected. No one needs to know but you and your provider.' },
        ].map((item) => (
          <details class="reveal group bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[20px]">
            <summary class="flex items-center justify-between px-5 sm:px-6 py-5 cursor-pointer text-text font-display font-light text-lg sm:text-xl">
              {item.q}
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 sm:px-6 pb-5 text-text/50 text-sm sm:text-base leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Ready to take the<br /><em class="text-primary italic">first step</em>?
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          A private, judgment-free evaluation with a licensed provider. Start with a conversation.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
