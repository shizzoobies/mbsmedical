---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Health & Wellness Tools" description="Free health and wellness calculators — estimate daily calories, project weekly weight loss, and discover calories burned by activity.">

  <!-- Hero -->
  <section class="pt-40 pb-20 sm:pt-48 sm:pb-28" style="background: linear-gradient(160deg, #0a0f1a 0%, #080808 50%, #0f1a14 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <span class="label text-primary block mb-5">Free Tools</span>
        <h1 class="font-display font-light text-[clamp(2.8rem,6vw,5rem)] leading-[1.05] tracking-[-0.03em] text-text mb-8">
          Health &amp; Wellness <em class="text-primary italic">Tools</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          Use these free calculators to explore estimates around your daily nutrition and activity. All results are general estimates and should not replace professional medical advice.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool Cards -->
  <section class="py-28 sm:py-36 border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">

        <!-- Calorie Calculator -->
        <button type="button" data-modal="calorie-calculator" class="reveal text-left bg-surface border border-border rounded-[24px] p-8 sm:p-10 hover:border-primary/40 hover:-translate-y-1 transition-all duration-300 cursor-pointer group">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" /></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-3">Daily Calorie Estimator</h3>
          <p class="text-text/40 text-sm leading-relaxed">Estimate your daily caloric needs based on age, weight, height, sex, and activity level using the Mifflin-St Jeor equation.</p>
          <span class="label text-primary mt-6 block group-hover:tracking-[0.2em] transition-all duration-300">Open Tool &rarr;</span>
        </button>

        <!-- Weight Loss Estimator -->
        <button type="button" data-modal="weight-loss" class="reveal reveal-delay-1 text-left bg-surface border border-border rounded-[24px] p-8 sm:p-10 hover:border-accent/40 hover:-translate-y-1 transition-all duration-300 cursor-pointer group">
          <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mb-6 group-hover:bg-accent/20 transition-colors">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-3">Weight Loss Projector</h3>
          <p class="text-text/40 text-sm leading-relaxed">Project your estimated weekly weight loss based on your stats, activity level, and daily calorie intake.</p>
          <span class="label text-accent mt-6 block group-hover:tracking-[0.2em] transition-all duration-300">Open Tool &rarr;</span>
        </button>

        <!-- Calories Burned -->
        <button type="button" data-modal="calories-burned" class="reveal reveal-delay-2 text-left bg-surface border border-border rounded-[24px] p-8 sm:p-10 hover:border-primary/40 hover:-translate-y-1 transition-all duration-300 cursor-pointer group">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" /></svg>
          </div>
          <h3 class="font-display font-light text-2xl text-text mb-3">Activity Calorie Burner</h3>
          <p class="text-text/40 text-sm leading-relaxed">Estimate how many calories you burn during different physical activities based on your weight and duration.</p>
          <span class="label text-primary mt-6 block group-hover:tracking-[0.2em] transition-all duration-300">Open Tool &rarr;</span>
        </button>

      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- MODAL: Daily Calorie Estimator               -->
  <!-- ============================================ -->
  <div id="calorie-calculator" class="modal-overlay fixed inset-0 z-[200] hidden items-start justify-center bg-black/70 backdrop-blur-sm overflow-y-auto overscroll-contain" style="-webkit-overflow-scrolling: touch;" role="dialog" aria-modal="true" aria-labelledby="calorie-title">
    <div class="modal-content bg-surface border border-border rounded-[24px] w-full max-w-xl mx-auto my-8 p-8 sm:p-10 relative mx-4 sm:mx-auto shrink-0">
      <button type="button" class="modal-close absolute top-5 right-5 text-text/40 hover:text-text transition-colors hidden sm:block" aria-label="Close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <button type="button" class="modal-close-mobile sm:hidden w-full flex items-center justify-center gap-2 py-3 mb-4 -mt-2 rounded-xl bg-bg border border-border text-text/50 text-sm font-ui font-semibold uppercase tracking-wider active:bg-surface">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        Close
      </button>
      <h2 id="calorie-title" class="font-display font-light text-3xl text-text mb-2">Daily Calorie Estimator</h2>
      <p class="text-text/40 text-sm mb-8">Uses the Mifflin-St Jeor equation to estimate your Total Daily Energy Expenditure (TDEE).</p>

      <form id="calorie-form" class="space-y-5">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label text-text/50 block mb-2">Age</label>
            <input type="number" name="age" min="15" max="100" required class="tool-input" placeholder="30" />
          </div>
          <div>
            <label class="label text-text/50 block mb-2">Sex</label>
            <select name="sex" required class="tool-input">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label text-text/50 block mb-2">Weight (lbs)</label>
            <input type="number" name="weight" min="50" max="700" step="0.1" required class="tool-input" placeholder="170" />
          </div>
          <div>
            <label class="label text-text/50 block mb-2">Height</label>
            <div class="flex gap-2">
              <input type="number" name="feet" min="3" max="7" required class="tool-input" placeholder="5" />
              <span class="text-text/30 self-center text-sm shrink-0">ft</span>
              <input type="number" name="inches" min="0" max="11" required class="tool-input" placeholder="8" />
              <span class="text-text/30 self-center text-sm shrink-0">in</span>
            </div>
          </div>
        </div>
        <div>
          <label class="label text-text/50 block mb-2">Activity Level</label>
          <select name="activity" required class="tool-input">
            <option value="1.2">Sedentary (little or no exercise)</option>
            <option value="1.375">Lightly active (1–3 days/week)</option>
            <option value="1.55" selected>Moderately active (3–5 days/week)</option>
            <option value="1.725">Very active (6–7 days/week)</option>
            <option value="1.9">Extremely active (physical job + exercise)</option>
          </select>
        </div>
        <button type="submit" class="w-full py-3 rounded-full bg-primary text-bg font-ui font-semibold text-sm uppercase tracking-wider hover:bg-accent transition-colors duration-300 cursor-pointer">Calculate</button>
      </form>

      <div id="calorie-result" class="mt-8 hidden">
        <div class="bg-bg border border-border rounded-2xl p-6 text-center">
          <span class="label text-primary block mb-2">Estimated Daily Calories</span>
          <p id="calorie-tdee" class="font-display text-5xl text-text mb-1"></p>
          <p class="text-text/40 text-sm">calories per day</p>
          <div class="mt-4 grid grid-cols-3 gap-3 text-center">
            <div class="bg-surface rounded-xl p-3">
              <span class="label text-text/30 block mb-1">Lose Weight</span>
              <p id="calorie-lose" class="font-display text-xl text-accent"></p>
            </div>
            <div class="bg-surface rounded-xl p-3">
              <span class="label text-text/30 block mb-1">Maintain</span>
              <p id="calorie-maintain" class="font-display text-xl text-primary"></p>
            </div>
            <div class="bg-surface rounded-xl p-3">
              <span class="label text-text/30 block mb-1">Gain Weight</span>
              <p id="calorie-gain" class="font-display text-xl text-text"></p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-text/25 text-xs mt-6 leading-relaxed">
        <strong class="text-text/40">Disclaimer:</strong> This tool provides general estimates only and is not a substitute for professional medical or nutritional advice. Individual caloric needs vary based on metabolism, genetics, medical conditions, and other factors. Consult a healthcare provider before making significant changes to your diet.
      </p>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MODAL: Weight Loss Projector                  -->
  <!-- ============================================ -->
  <div id="weight-loss" class="modal-overlay fixed inset-0 z-[200] hidden items-start justify-center bg-black/70 backdrop-blur-sm overflow-y-auto overscroll-contain" style="-webkit-overflow-scrolling: touch;" role="dialog" aria-modal="true" aria-labelledby="weightloss-title">
    <div class="modal-content bg-surface border border-border rounded-[24px] w-full max-w-xl mx-auto my-8 p-8 sm:p-10 relative mx-4 sm:mx-auto shrink-0">
      <button type="button" class="modal-close absolute top-5 right-5 text-text/40 hover:text-text transition-colors hidden sm:block" aria-label="Close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <button type="button" class="modal-close-mobile sm:hidden w-full flex items-center justify-center gap-2 py-3 mb-4 -mt-2 rounded-xl bg-bg border border-border text-text/50 text-sm font-ui font-semibold uppercase tracking-wider active:bg-surface">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        Close
      </button>
      <h2 id="weightloss-title" class="font-display font-light text-3xl text-text mb-2">Weight Loss Projector</h2>
      <p class="text-text/40 text-sm mb-8">Estimate weekly weight change based on your TDEE and planned daily calorie intake.</p>

      <form id="weightloss-form" class="space-y-5">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label text-text/50 block mb-2">Age</label>
            <input type="number" name="age" min="15" max="100" required class="tool-input" placeholder="30" />
          </div>
          <div>
            <label class="label text-text/50 block mb-2">Sex</label>
            <select name="sex" required class="tool-input">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label text-text/50 block mb-2">Weight (lbs)</label>
            <input type="number" name="weight" min="50" max="700" step="0.1" required class="tool-input" placeholder="170" />
          </div>
          <div>
            <label class="label text-text/50 block mb-2">Height</label>
            <div class="flex gap-2">
              <input type="number" name="feet" min="3" max="7" required class="tool-input" placeholder="5" />
              <span class="text-text/30 self-center text-sm shrink-0">ft</span>
              <input type="number" name="inches" min="0" max="11" required class="tool-input" placeholder="8" />
              <span class="text-text/30 self-center text-sm shrink-0">in</span>
            </div>
          </div>
        </div>
        <div>
          <label class="label text-text/50 block mb-2">Activity Level</label>
          <select name="activity" required class="tool-input">
            <option value="1.2">Sedentary (little or no exercise)</option>
            <option value="1.375">Lightly active (1–3 days/week)</option>
            <option value="1.55" selected>Moderately active (3–5 days/week)</option>
            <option value="1.725">Very active (6–7 days/week)</option>
            <option value="1.9">Extremely active (physical job + exercise)</option>
          </select>
        </div>
        <div>
          <label class="label text-text/50 block mb-2">Daily Calorie Intake (planned)</label>
          <input type="number" name="intake" min="800" max="10000" required class="tool-input" placeholder="1500" />
        </div>
        <button type="submit" class="w-full py-3 rounded-full bg-accent text-bg font-ui font-semibold text-sm uppercase tracking-wider hover:bg-primary transition-colors duration-300 cursor-pointer">Project Weight Loss</button>
      </form>

      <div id="weightloss-result" class="mt-8 hidden">
        <div class="bg-bg border border-border rounded-2xl p-6 text-center">
          <span class="label text-accent block mb-2">Estimated Weekly Change</span>
          <p id="weightloss-weekly" class="font-display text-5xl text-text mb-1"></p>
          <p class="text-text/40 text-sm mb-4">pounds per week</p>
          <div class="grid grid-cols-2 gap-3 text-center">
            <div class="bg-surface rounded-xl p-3">
              <span class="label text-text/30 block mb-1">Your TDEE</span>
              <p id="weightloss-tdee" class="font-display text-xl text-primary"></p>
            </div>
            <div class="bg-surface rounded-xl p-3">
              <span class="label text-text/30 block mb-1">Daily Deficit</span>
              <p id="weightloss-deficit" class="font-display text-xl text-accent"></p>
            </div>
          </div>
          <div class="mt-4 bg-surface rounded-xl p-3 text-center">
            <span class="label text-text/30 block mb-1">Projected in 4 Weeks</span>
            <p id="weightloss-monthly" class="font-display text-xl text-text"></p>
          </div>
        </div>
      </div>

      <p class="text-text/25 text-xs mt-6 leading-relaxed">
        <strong class="text-text/40">Disclaimer:</strong> This tool provides rough estimates based on the commonly cited approximation that 3,500 calories equals one pound of body weight. Actual weight loss varies significantly based on metabolism, body composition, water retention, hormonal factors, and other individual variables. Very low calorie diets can be dangerous — always consult a healthcare provider before starting any weight loss program. This is not medical advice.
      </p>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MODAL: Activity Calorie Burner                -->
  <!-- ============================================ -->
  <div id="calories-burned" class="modal-overlay fixed inset-0 z-[200] hidden items-start justify-center bg-black/70 backdrop-blur-sm overflow-y-auto overscroll-contain" style="-webkit-overflow-scrolling: touch;" role="dialog" aria-modal="true" aria-labelledby="activity-title">
    <div class="modal-content bg-surface border border-border rounded-[24px] w-full max-w-xl mx-auto my-8 p-8 sm:p-10 relative mx-4 sm:mx-auto shrink-0">
      <button type="button" class="modal-close absolute top-5 right-5 text-text/40 hover:text-text transition-colors hidden sm:block" aria-label="Close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <button type="button" class="modal-close-mobile sm:hidden w-full flex items-center justify-center gap-2 py-3 mb-4 -mt-2 rounded-xl bg-bg border border-border text-text/50 text-sm font-ui font-semibold uppercase tracking-wider active:bg-surface">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        Close
      </button>
      <h2 id="activity-title" class="font-display font-light text-3xl text-text mb-2">Activity Calorie Burner</h2>
      <p class="text-text/40 text-sm mb-8">Estimate calories burned during different activities using MET (Metabolic Equivalent of Task) values.</p>

      <form id="activity-form" class="space-y-5">
        <div>
          <label class="label text-text/50 block mb-2">Weight (lbs)</label>
          <input type="number" name="weight" min="50" max="700" step="0.1" required class="tool-input" placeholder="170" />
        </div>
        <div>
          <label class="label text-text/50 block mb-2">Duration (minutes)</label>
          <input type="number" name="duration" min="1" max="600" required class="tool-input" placeholder="30" />
        </div>
        <button type="submit" class="w-full py-3 rounded-full bg-primary text-bg font-ui font-semibold text-sm uppercase tracking-wider hover:bg-accent transition-colors duration-300 cursor-pointer">Calculate All Activities</button>
      </form>

      <div id="activity-result" class="mt-8 hidden">
        <div class="bg-bg border border-border rounded-2xl p-5">
          <div class="flex items-center justify-between mb-4">
            <span class="label text-primary">Estimated Calories Burned</span>
            <span id="activity-meta" class="text-text/30 text-xs"></span>
          </div>
          <div id="activity-list" class="space-y-2"></div>
        </div>
      </div>

      <p class="text-text/25 text-xs mt-6 leading-relaxed">
        <strong class="text-text/40">Disclaimer:</strong> Calorie burn estimates are based on published MET values and are approximate. Actual calories burned depend on individual fitness level, intensity, body composition, environmental conditions, and other factors. These figures are intended for general informational purposes only and are not a substitute for professional guidance.
      </p>
    </div>
  </div>

</Layout>

<!-- ============================================ -->
<!-- STYLES                                        -->
<!-- ============================================ -->
<style>
  .tool-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(237, 233, 224, 0.1);
    background: #080808;
    color: #EDE9E0;
    font-family: var(--font-body);
    font-size: 0.9rem;
    transition: border-color 0.3s;
    appearance: none;
  }
  .tool-input:focus {
    outline: none;
    border-color: #44BDB7;
  }
  .tool-input option {
    background: #080808;
    color: #EDE9E0;
  }

  .modal-overlay {
    transition: opacity 0.3s ease;
    -webkit-overflow-scrolling: touch;
    padding: 0;
  }
  .modal-overlay.active {
    display: flex;
  }
  .modal-content {
    animation: modal-enter 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    margin-left: 1rem;
    margin-right: 1rem;
  }
  @media (min-width: 640px) {
    .modal-content {
      margin-left: auto;
      margin-right: auto;
    }
  }
  @keyframes modal-enter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Activity row styling */
  :global(.activity-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.75rem;
    border-radius: 10px;
    transition: background 0.2s;
  }
  :global(.activity-row:hover) {
    background: rgba(237, 233, 224, 0.03);
  }
  :global(.activity-name) {
    color: rgba(237, 233, 224, 0.6);
    font-size: 0.85rem;
  }
  :global(.activity-cal) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: #EDE9E0;
  }
</style>

<!-- ============================================ -->
<!-- SCRIPTS                                       -->
<!-- ============================================ -->
<script>
  // --- Scroll reveals ---
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // --- Modal management (iOS-safe scroll lock) ---
  let scrollY = 0;

  function openModal(id: string) {
    const modal = document.getElementById(id);
    if (modal) {
      scrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';
      modal.classList.add('active');
      modal.scrollTop = 0;
      const firstInput = modal.querySelector('input, select') as HTMLElement;
      if (firstInput) setTimeout(() => firstInput.focus(), 100);
    }
  }

  function closeModal(overlay: Element) {
    overlay.classList.remove('active');
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.overflow = '';
    window.scrollTo(0, scrollY);
  }

  // Open on card click
  document.querySelectorAll<HTMLElement>('[data-modal]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal');
      if (modalId) openModal(modalId);
    });
  });

  // Close on X button (desktop) and Close bar (mobile)
  document.querySelectorAll('.modal-close, .modal-close-mobile').forEach((btn) => {
    btn.addEventListener('click', () => {
      const overlay = btn.closest('.modal-overlay');
      if (overlay) closeModal(overlay);
    });
  });

  // Close on overlay click
  document.querySelectorAll('.modal-overlay').forEach((overlay) => {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal(overlay);
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-overlay.active').forEach((m) => closeModal(m));
    }
  });

  // --- Utility: Calculate BMR (Mifflin-St Jeor) ---
  function calcBMR(weightLbs: number, heightIn: number, age: number, sex: string): number {
    const weightKg = weightLbs * 0.453592;
    const heightCm = heightIn * 2.54;
    if (sex === 'male') {
      return 10 * weightKg + 6.25 * heightCm - 5 * age + 5;
    }
    return 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
  }

  // --- Calorie Calculator ---
  const calorieForm = document.getElementById('calorie-form') as HTMLFormElement;
  calorieForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(calorieForm);
    const age = Number(data.get('age'));
    const sex = data.get('sex') as string;
    const weight = Number(data.get('weight'));
    const height = Number(data.get('feet')) * 12 + Number(data.get('inches'));
    const activity = Number(data.get('activity'));

    const bmr = calcBMR(weight, height, age, sex);
    const tdee = Math.round(bmr * activity);

    (document.getElementById('calorie-tdee') as HTMLElement).textContent = tdee.toLocaleString();
    (document.getElementById('calorie-lose') as HTMLElement).textContent = (tdee - 500).toLocaleString();
    (document.getElementById('calorie-maintain') as HTMLElement).textContent = tdee.toLocaleString();
    (document.getElementById('calorie-gain') as HTMLElement).textContent = (tdee + 500).toLocaleString();
    const calorieResult = document.getElementById('calorie-result') as HTMLElement;
    calorieResult.classList.remove('hidden');
    setTimeout(() => calorieResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  });

  // --- Weight Loss Projector ---
  const weightlossForm = document.getElementById('weightloss-form') as HTMLFormElement;
  weightlossForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(weightlossForm);
    const age = Number(data.get('age'));
    const sex = data.get('sex') as string;
    const weight = Number(data.get('weight'));
    const height = Number(data.get('feet')) * 12 + Number(data.get('inches'));
    const activity = Number(data.get('activity'));
    const intake = Number(data.get('intake'));

    const bmr = calcBMR(weight, height, age, sex);
    const tdee = Math.round(bmr * activity);
    const deficit = tdee - intake;
    const weeklyLbs = deficit * 7 / 3500;
    const monthlyLbs = weeklyLbs * 4;

    const sign = weeklyLbs >= 0 ? '-' : '+';
    const absWeekly = Math.abs(weeklyLbs).toFixed(1);
    const absMonthly = Math.abs(monthlyLbs).toFixed(1);

    (document.getElementById('weightloss-tdee') as HTMLElement).textContent = tdee.toLocaleString() + ' cal';
    (document.getElementById('weightloss-deficit') as HTMLElement).textContent = (deficit >= 0 ? '-' : '+') + Math.abs(deficit).toLocaleString() + ' cal';
    (document.getElementById('weightloss-weekly') as HTMLElement).textContent = sign + absWeekly;
    (document.getElementById('weightloss-monthly') as HTMLElement).textContent = sign + absMonthly + ' lbs';
    const weightlossResult = document.getElementById('weightloss-result') as HTMLElement;
    weightlossResult.classList.remove('hidden');
    setTimeout(() => weightlossResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  });

  // --- Activity Calorie Burner ---
  const activities = [
    { name: 'Walking (3 mph)', met: 3.5 },
    { name: 'Brisk Walking (4 mph)', met: 5.0 },
    { name: 'Jogging (5 mph)', met: 7.0 },
    { name: 'Running (6 mph)', met: 9.8 },
    { name: 'Running (8 mph)', met: 11.8 },
    { name: 'Cycling (moderate)', met: 6.8 },
    { name: 'Cycling (vigorous)', met: 10.0 },
    { name: 'Swimming (moderate)', met: 6.0 },
    { name: 'Swimming (vigorous)', met: 9.8 },
    { name: 'Jump Rope', met: 11.0 },
    { name: 'Rowing Machine', met: 7.0 },
    { name: 'Elliptical Trainer', met: 5.0 },
    { name: 'Weight Lifting (general)', met: 3.5 },
    { name: 'Weight Lifting (vigorous)', met: 6.0 },
    { name: 'Yoga', met: 3.0 },
    { name: 'Pilates', met: 3.0 },
    { name: 'HIIT / CrossFit', met: 8.0 },
    { name: 'Dancing (general)', met: 4.8 },
    { name: 'Hiking (moderate)', met: 5.3 },
    { name: 'Hiking (steep/uphill)', met: 7.5 },
    { name: 'Basketball', met: 6.5 },
    { name: 'Soccer', met: 7.0 },
    { name: 'Tennis (singles)', met: 8.0 },
    { name: 'Golf (walking w/ clubs)', met: 4.3 },
    { name: 'Gardening', met: 3.8 },
    { name: 'Housework (general)', met: 2.5 },
    { name: 'Stair Climbing', met: 9.0 },
    { name: 'Martial Arts', met: 10.3 },
  ];

  const activityForm = document.getElementById('activity-form') as HTMLFormElement;
  activityForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(activityForm);
    const weight = Number(data.get('weight'));
    const duration = Number(data.get('duration'));
    const weightKg = weight * 0.453592;

    const listEl = document.getElementById('activity-list') as HTMLElement;
    const metaEl = document.getElementById('activity-meta') as HTMLElement;
    metaEl.textContent = `${weight} lbs · ${duration} min`;

    listEl.innerHTML = activities
      .map((a) => {
        const cal = Math.round((a.met * weightKg * duration) / 60);
        return `<div class="activity-row"><span class="activity-name">${a.name}</span><span class="activity-cal">${cal.toLocaleString()}</span></div>`;
      })
      .join('');

    const activityResult = document.getElementById('activity-result') as HTMLElement;
    activityResult.classList.remove('hidden');
    setTimeout(() => activityResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  });
</script>
