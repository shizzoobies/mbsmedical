---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Birth Control" description="Private, provider-guided contraceptive management via telehealth. Prescriptions, refills, and method changes — all from home. MBS Medical serves patients across Florida.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #1a0f14 0%, #080808 50%, #14101e 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="max-w-xl">
          <span class="label text-accent block mb-5">Birth Control</span>
          <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
            Birth control<br />on <em class="text-accent italic">your terms</em>
          </h1>
          <p class="text-text/50 text-base sm:text-lg leading-relaxed mb-10">
            Private, provider-guided contraceptive management via telehealth. Prescriptions, refills, and method changes — all from home.
          </p>
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
        </div>
        <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center">
          <span class="text-text-muted text-sm">Image Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">What We Offer</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">Contraceptive care that fits <em class="text-accent italic">your life</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Oral Contraceptives</h3>
          <p class="text-text/50 text-sm leading-relaxed">Pill prescriptions and refills managed through convenient telehealth visits — no need to come in just to keep your prescription current.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Method Counseling</h3>
          <p class="text-text/50 text-sm leading-relaxed">Not sure what's right for you? We'll help you understand your options and choose the method that works best for your body and your lifestyle.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#C06E9F]/40 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-4">Ongoing Management</h3>
          <p class="text-text/50 text-sm leading-relaxed">Side effect monitoring, dosage adjustments, and method switches when something isn't working — we stay with you through the process.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 sm:py-36 border-t border-border relative" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·∘⊹" cellSize={24} radius={140} baseOpacity={0.03} />
    <div class="relative z-2 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-accent block mb-5">Common Questions</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] text-text">What you need to <em class="text-accent italic">know</em></h2>
      </div>
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl">
        <div class="reveal">
          <h3 class="font-display font-light text-2xl text-text mb-3">Can you prescribe birth control via telehealth?</h3>
          <p class="text-text/50 text-base leading-relaxed">Yes. After a thorough telehealth evaluation — including a review of your medical history, blood pressure, and risk factors — we can prescribe or refill oral contraceptives and other eligible methods without an in-person visit.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <h3 class="font-display font-light text-2xl text-text mb-3">What methods do you offer?</h3>
          <p class="text-text/50 text-base leading-relaxed">We prescribe oral contraceptive pills, patches, and vaginal rings via telehealth. For methods that require a procedure — like IUDs or implants — we can counsel you on options and coordinate with a local provider for placement.</p>
        </div>
        <div class="reveal reveal-delay-2">
          <h3 class="font-display font-light text-2xl text-text mb-3">Do I need an exam first?</h3>
          <p class="text-text/50 text-base leading-relaxed">In many cases, no. A detailed health history and risk assessment is often sufficient to prescribe hormonal contraception. We'll let you know if any additional evaluation is needed based on your individual situation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Take control of your<br /><em class="text-accent italic">health</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit and talk to a provider who respects your choices and makes contraceptive care simple, private, and stress-free.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-accent">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
