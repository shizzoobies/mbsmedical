---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Acne Treatment" description="Clinical acne evaluation and prescription treatment via telehealth. From mild breakouts to persistent acne — we build a plan that works.">

  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #0a1a14 0%, #080808 50%, #0f0a1a 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">Acne Treatment</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Clear skin starts<br />with a real <em class="text-primary italic">plan</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px] mb-10">
          Clinical acne evaluation and prescription treatment via telehealth. From mild breakouts to persistent acne — we build a plan that works.
        </p>
        <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
      </div>
    </div>
  </section>

  <!-- How We Treat Acne -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center mb-6"><span class="text-text-muted text-sm">Image Placeholder</span></div>
          <h3 class="font-display font-light text-2xl text-text mb-4">Skin Assessment</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Photo-based evaluation of acne type and severity</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Review of skin history, past treatments, and current routine</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Classification of comedonal, inflammatory, or cystic patterns</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center mb-6"><span class="text-text-muted text-sm">Image Placeholder</span></div>
          <h3 class="font-display font-light text-2xl text-text mb-4">Prescription Treatment</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Topical retinoids tailored to skin sensitivity and acne grade</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Antibiotic therapy for inflammatory and bacterial components</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Combination therapy protocols for moderate to severe cases</li>
          </ul>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10 hover:border-[#3AABA5]/40 hover:-translate-y-1 transition-all duration-300">
          <div class="rounded-2xl overflow-hidden bg-surface-light aspect-[16/10] flex items-center justify-center mb-6"><span class="text-text-muted text-sm">Image Placeholder</span></div>
          <h3 class="font-display font-light text-2xl text-text mb-4">Follow-Up Monitoring</h3>
          <ul class="space-y-3 text-text/50 text-sm">
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Treatment response tracking with photo comparison</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Regimen adjustments based on progress and side effects</li>
            <li class="flex gap-3"><span class="text-primary mt-0.5">&#8226;</span> Long-term maintenance planning to prevent recurrence</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 sm:py-28 relative" style="background: linear-gradient(160deg, #14101e 0%, #0c0c0c 50%, #0a1410 100%);">
    <AsciiHover charset="+" cellSize={24} radius={120} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl mx-auto">
        <span class="label text-primary block mb-5 text-center">FAQ</span>
        <div class="space-y-8">
          <div class="bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10">
            <h3 class="font-display font-light text-xl text-text mb-3">Can acne be treated via telehealth?</h3>
            <p class="text-text/50 text-sm leading-relaxed">Yes. Most acne can be effectively diagnosed and treated through photo-based assessment and video consultation. Your provider will evaluate your skin, prescribe appropriate medications, and monitor your progress remotely.</p>
          </div>
          <div class="bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10">
            <h3 class="font-display font-light text-xl text-text mb-3">What medications do you prescribe?</h3>
            <p class="text-text/50 text-sm leading-relaxed">We prescribe topical retinoids, topical and oral antibiotics, benzoyl peroxide formulations, and combination therapies. Your treatment plan is tailored to your acne type, severity, and skin sensitivity.</p>
          </div>
          <div class="bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 sm:p-10">
            <h3 class="font-display font-light text-xl text-text mb-3">How long does treatment take?</h3>
            <p class="text-text/50 text-sm leading-relaxed">Most patients see noticeable improvement within 6 to 12 weeks. Significant clearing typically occurs over 3 to 6 months. Your provider will schedule follow-ups to track progress and adjust treatment as needed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Start your clear skin <em class="text-primary italic">journey</em>
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit to get a personalized acne treatment plan from a licensed provider.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
<script>
  const observer = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
