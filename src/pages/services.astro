---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';
---

<Layout title="Services" description="MBS Medical services: primary care, clinically supervised weight loss, and testosterone evaluation. Telehealth across Florida.">

  <!-- Hero -->
  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #0a0f1a 0%, #080808 50%, #0f1a14 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">Our Services</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Care that fits<br />your <em class="text-primary italic">life</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px]">
          Three focused services designed around continuity, honesty, and real access to your provider. All delivered via telehealth across Florida.
        </p>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section class="pb-28 sm:pb-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">

      <a href="/primary-care/" class="reveal group block py-12 lg:py-16 border-t border-border">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div>
            <h2 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Primary Care</h2>
            <p class="text-text/50 text-base leading-relaxed mb-4 max-w-[520px]">Routine visits, medication management, chronic condition care — all from a provider who knows your full history. Hypertension, diabetes, cholesterol, hypothyroidism, GERD, and more.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              Learn More <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="rounded-2xl overflow-hidden">
            <img src="/images/primary-care.png" alt="Primary Care" class="w-full h-auto rounded-2xl group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

      <a href="/weight-loss/" class="reveal group block py-12 lg:py-16 border-t border-border" style="background: linear-gradient(135deg, rgba(10,15,10,0.5), transparent);">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="lg:order-2">
            <h2 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Weight Loss</h2>
            <p class="text-text/50 text-base leading-relaxed mb-4 max-w-[520px]">Clinically supervised weight management with GLP-1 evaluation. Initial consultation, medication-assisted options, and ongoing monitoring with real provider oversight.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              Learn More <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="aspect-[16/10] rounded-2xl overflow-hidden lg:order-1">
            <img src="/images/weight-loss.png" alt="Weight Loss" class="w-full h-auto rounded-2xl group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

      <a href="/trt/" class="reveal group block py-12 lg:py-16 border-t border-border">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div>
            <h2 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">TRT Evaluation</h2>
            <p class="text-text/50 text-base leading-relaxed mb-4 max-w-[520px]">Lab-driven testosterone assessment with honest evaluation. Comprehensive symptom review, bloodwork panels, and ongoing monitoring if treatment is appropriate.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              Learn More <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="rounded-2xl overflow-hidden">
            <img src="/images/trt.png" alt="TRT Evaluation" class="w-full h-auto rounded-2xl group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

      <!-- Service 4: Sleep Issues -->
      <a href="/sleep/" class="reveal group block py-12 lg:py-16 border-t border-b border-border" style="background: linear-gradient(135deg, rgba(20,16,30,0.3), transparent);">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="lg:order-2">
            <h2 class="font-display font-light text-[clamp(2rem,4vw,3.25rem)] leading-[1.1] text-text group-hover:text-accent transition-colors duration-300 mb-4">Sleep Issues</h2>
            <p class="text-text/50 text-base leading-relaxed mb-4 max-w-[520px]">Restless nights running your days? We evaluate what's behind your sleep issues and build a plan that helps — difficulty falling asleep, staying asleep, or daytime exhaustion.</p>
            <span class="inline-flex items-center gap-3 label text-accent group-hover:gap-5 transition-all duration-300">
              Learn More <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
          <div class="aspect-[16/10] rounded-2xl overflow-hidden lg:order-1">
            <img src="/images/sleep.jpg" alt="Sleep Issues" class="w-full h-auto rounded-2xl group-hover:scale-105 transition-transform duration-700" />
          </div>
        </div>
      </a>

    </div>
  </section>

  <!-- How It Works -->
  <section class="py-28 sm:py-36 border-t border-border relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">How It Works</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text">Getting started is <em class="text-primary italic">simple</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-12 lg:gap-16">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 hover:border-accent hover:translate-y-[-2px] transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-3">Book online</h3>
          <p class="text-text/40 text-base leading-relaxed">Schedule through our secure HIPAA-compliant patient portal. Same-week availability.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 hover:border-accent hover:translate-y-[-2px] transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-3">Complete your intake</h3>
          <p class="text-text/40 text-base leading-relaxed">Brief health history — your provider reviews it before your visit so you spend time on care, not paperwork.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 hover:border-accent hover:translate-y-[-2px] transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-3">Meet your provider</h3>
          <p class="text-text/40 text-base leading-relaxed">Connect via telehealth and build a care plan together. Follow-ups, labs, and prescriptions managed through the portal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Not sure where<br />to <em class="text-primary italic">start</em>?
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit or send us a question. We'll help you figure out the right path forward.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-accent {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .btn-accent:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
