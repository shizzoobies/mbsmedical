---
import Layout from '../layouts/Layout.astro';
import AsciiHover from '../components/AsciiHover.astro';

const categories = [
  {
    label: 'Core Services',
    color: 'primary',
    items: [
      { href: '/primary-care/', title: 'Primary Care', desc: 'Routine visits, chronic condition care, and medication oversight from a provider who knows your full history.' },
      { href: '/weight-loss/', title: 'Weight Loss', desc: 'Clinically supervised weight management with GLP-1 evaluation, personalized plans, and ongoing monitoring.' },
      { href: '/sleep/', title: 'Sleep Issues', desc: 'Evaluation and treatment for difficulty falling asleep, staying asleep, or daytime exhaustion.' },
    ],
  },
  {
    label: "Men's Health",
    color: 'primary',
    items: [
      { href: '/trt/', title: 'TRT Evaluation', desc: 'Lab-driven testosterone assessment with honest evaluation. If TRT is right, we build a plan. If not, we tell you.' },
      { href: '/erectile-dysfunction/', title: 'Erectile Dysfunction', desc: 'Discreet, clinical evaluation and treatment for ED. Real conversation, no judgment.' },
      { href: '/hair-loss/', title: 'Hair Loss', desc: 'Evidence-based evaluation and treatment for hair thinning and loss with FDA-approved options.' },
    ],
  },
  {
    label: "Women's Health",
    color: 'accent',
    items: [
      { href: '/birth-control/', title: 'Birth Control', desc: 'Private, provider-guided contraceptive management. Prescriptions, refills, and method changes.' },
      { href: '/uti-treatment/', title: 'UTI Treatment', desc: 'Same-day telehealth evaluation and treatment for urinary tract infections.' },
      { href: '/menopause/', title: 'Menopause', desc: 'Comprehensive menopause management — hot flashes, mood changes, sleep disruption, and more.' },
    ],
  },
  {
    label: 'Mental Health',
    color: 'accent',
    items: [
      { href: '/anxiety/', title: 'Anxiety', desc: 'Clinical evaluation and medication management for generalized anxiety, social anxiety, and panic disorder.' },
      { href: '/depression/', title: 'Depression', desc: 'Compassionate support with medication management and ongoing care for depression.' },
      { href: '/adhd/', title: 'ADHD', desc: 'Adult ADHD evaluation and medication management with structured assessment and ongoing support.' },
    ],
  },
  {
    label: 'Skin Care',
    color: 'primary',
    items: [
      { href: '/acne/', title: 'Acne', desc: 'Clinical acne evaluation and prescription treatment — from mild breakouts to persistent acne.' },
      { href: '/eczema/', title: 'Eczema', desc: 'Ongoing eczema management with flare-up treatment, maintenance therapy, and trigger identification.' },
      { href: '/rosacea/', title: 'Rosacea', desc: 'Clinical evaluation and treatment to reduce redness, manage flare-ups, and build a long-term plan.' },
    ],
  },
  {
    label: 'Acute Care',
    color: 'primary',
    items: [
      { href: '/cold-flu/', title: 'Cold & Flu', desc: 'Same-day evaluation for cold and flu symptoms. Quick treatment plans and prescriptions when needed.' },
      { href: '/sinus-infections/', title: 'Sinus Infections', desc: 'Clinical evaluation and treatment for acute and recurring sinus infections.' },
      { href: '/allergies/', title: 'Allergies', desc: 'Seasonal and year-round allergy management with medication optimization.' },
      { href: '/pink-eye/', title: 'Pink Eye', desc: 'Same-day evaluation for conjunctivitis with photo-based assessment and treatment.' },
    ],
  },
  {
    label: 'Chronic Conditions',
    color: 'primary',
    items: [
      { href: '/diabetes/', title: 'Diabetes', desc: 'Type 2 diabetes and pre-diabetes care with lab monitoring and medication management.' },
      { href: '/cholesterol/', title: 'Cholesterol', desc: 'Lipid panel monitoring, statin management, and cardiovascular risk assessment.' },
      { href: '/thyroid/', title: 'Thyroid', desc: 'Hypothyroidism and thyroid disorder management with regular lab monitoring.' },
    ],
  },
  {
    label: 'Lifestyle',
    color: 'accent',
    items: [
      { href: '/smoking-cessation/', title: 'Smoking Cessation', desc: 'Evidence-based quit support with prescription options and ongoing coaching.' },
      { href: '/sexual-health/', title: 'Sexual Health', desc: 'Discreet STI screening, treatment, and preventive care from the privacy of home.' },
    ],
  },
  {
    label: 'GI Health',
    color: 'accent',
    items: [
      { href: '/gerd/', title: 'GERD', desc: 'Acid reflux management with medication optimization and lifestyle modification.' },
      { href: '/ibs/', title: 'IBS', desc: 'Ongoing IBS management with symptom tracking, dietary guidance, and medication optimization.' },
    ],
  },
];
---

<Layout title="Services" description="MBS Medical services: primary care, weight loss, mental health, skin care, chronic conditions, and more. Telehealth across Florida.">

  <!-- Hero -->
  <section class="pt-40 pb-28 sm:pt-48 sm:pb-36" style="background: linear-gradient(160deg, #0a0f1a 0%, #080808 50%, #0f1a14 100%);">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="label text-primary block mb-5">Our Services</span>
        <h1 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Comprehensive care,<br />one <em class="text-primary italic">provider</em>
        </h1>
        <p class="text-text/50 text-base sm:text-lg leading-relaxed max-w-[540px]">
          From primary care to mental health, skin conditions to chronic disease management — all delivered via telehealth across Florida by a provider who knows your full picture.
        </p>
      </div>
    </div>
  </section>

  <!-- Service Categories -->
  {categories.map((cat, catIdx) => (
    <section
      class:list={['py-16 sm:py-20', catIdx % 2 === 1 ? '' : 'border-t border-border']}
      style={catIdx % 2 === 1 ? `background: linear-gradient(160deg, ${catIdx % 4 === 1 ? '#14101e 0%, #0c0c0c 50%, #0a1410' : '#0f1a14 0%, #0c0c0c 50%, #1a0f14'} 100%);` : undefined}
    >
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
        <div class="reveal mb-10">
          <h2 class:list={['label block mb-3', cat.color === 'accent' ? 'text-accent' : 'text-primary']}>{cat.label}</h2>
        </div>
        <div class:list={['grid gap-5', cat.items.length === 4 ? 'sm:grid-cols-2 lg:grid-cols-4' : cat.items.length === 2 ? 'sm:grid-cols-2 lg:grid-cols-2 max-w-4xl' : 'sm:grid-cols-2 lg:grid-cols-3']}>
          {cat.items.map((item, i) => (
            <a
              href={item.href}
              class:list={[
                'reveal group bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-7 sm:p-8 transition-all duration-300 no-underline block',
                cat.color === 'accent' ? 'hover:border-[#C06E9F]/40' : 'hover:border-[#3AABA5]/40',
                'hover:-translate-y-1',
                i > 0 && `reveal-delay-${Math.min(i, 3)}`,
              ]}
            >
              <h3 class:list={['font-display font-light text-2xl text-text mb-3 group-hover:transition-colors duration-300', cat.color === 'accent' ? 'group-hover:text-accent' : 'group-hover:text-primary']}>{item.title}</h3>
              <p class="text-text/40 text-sm leading-relaxed mb-5">{item.desc}</p>
              <span class:list={['inline-flex items-center gap-2 label group-hover:gap-4 transition-all duration-300', cat.color === 'accent' ? 'text-accent' : 'text-primary']}>
                Learn More <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- How It Works -->
  <section class="py-28 sm:py-36 border-t border-border relative overflow-hidden" style="background: linear-gradient(160deg, #0f1a14 0%, #0c0c0c 50%, #1a0f14 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="label text-primary block mb-5">How It Works</span>
        <h2 class="font-display font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.02em] text-text">Getting started is <em class="text-primary italic">simple</em></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-12 lg:gap-16">
        <div class="reveal reveal-delay-1 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 hover:border-accent hover:translate-y-[-2px] transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-3">Book online</h3>
          <p class="text-text/40 text-base leading-relaxed">Schedule through our secure HIPAA-compliant patient portal. Same-week availability.</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 hover:border-accent hover:translate-y-[-2px] transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-3">Complete your intake</h3>
          <p class="text-text/40 text-base leading-relaxed">Brief health history — your provider reviews it before your visit so you spend time on care, not paperwork.</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#0F0F0F] border border-[rgba(237,233,224,0.1)] rounded-[24px] p-8 hover:border-accent hover:translate-y-[-2px] transition-all duration-300">
          <h3 class="font-display font-light text-2xl text-text mb-3">Meet your provider</h3>
          <p class="text-text/40 text-base leading-relaxed">Connect via telehealth and build a care plan together. Follow-ups, labs, and prescriptions managed through the portal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-36 sm:py-44 relative overflow-hidden" style="background: linear-gradient(160deg, #1a0f14 0%, #0c0c0c 50%, #0a0f1a 100%);">
    <AsciiHover charset="·+×∘⊹" radius={200} baseOpacity={0.03} />
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <h2 class="font-display font-light text-[clamp(3rem,7vw,5.5rem)] leading-[1.0] tracking-[-0.03em] text-text mb-8">
          Not sure where<br />to <em class="text-primary italic">start</em>?
        </h2>
        <p class="text-text/50 text-lg leading-relaxed mb-12 max-w-[580px] mx-auto">
          Book a visit or send us a question. We'll help you figure out the right path forward.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="https://mbsmedical.practicebetter.io" target="_blank" rel="noopener noreferrer" class="btn-pill btn-primary">Book a Visit</a>
          <a href="/contact/" class="btn-pill btn-outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .btn-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: 48px;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-primary);
  }
  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid rgba(232, 228, 224, 0.2);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
