---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="group block bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl hover:shadow-primary/10 border border-warm-dark/10 transition-all duration-300 hover:-translate-y-1">
  <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-primary/20 transition-colors">
    <Fragment set:html={icon} />
  </div>
  <h3 class="font-heading text-xl text-primary-dark mb-3">{title}</h3>
  <p class="text-text-light text-sm leading-relaxed mb-4">{description}</p>
  <span class="inline-flex items-center gap-1.5 text-primary font-medium text-sm group-hover:gap-2.5 transition-all">
    Learn more
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </span>
</a>
