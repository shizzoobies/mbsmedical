---
const currentPath = Astro.url.pathname;

const serviceCategories = [
  {
    label: 'Core Services',
    items: [
      { href: '/primary-care/', label: 'Primary Care' },
      { href: '/weight-loss/', label: 'Weight Loss' },
      { href: '/sleep/', label: 'Sleep Issues' },
    ],
  },
  {
    label: "Men's Health",
    items: [
      { href: '/trt/', label: 'TRT Evaluation' },
      { href: '/erectile-dysfunction/', label: 'Erectile Dysfunction' },
      { href: '/hair-loss/', label: 'Hair Loss' },
    ],
  },
  {
    label: "Women's Health",
    items: [
      { href: '/birth-control/', label: 'Birth Control' },
      { href: '/uti-treatment/', label: 'UTI Treatment' },
      { href: '/menopause/', label: 'Menopause' },
    ],
  },
  {
    label: 'Mental Health',
    items: [
      { href: '/anxiety/', label: 'Anxiety' },
      { href: '/depression/', label: 'Depression' },
      { href: '/adhd/', label: 'ADHD' },
    ],
  },
  {
    label: 'Skin Care',
    items: [
      { href: '/acne/', label: 'Acne' },
      { href: '/eczema/', label: 'Eczema' },
      { href: '/rosacea/', label: 'Rosacea' },
    ],
  },
  {
    label: 'Acute Care',
    items: [
      { href: '/cold-flu/', label: 'Cold & Flu' },
      { href: '/sinus-infections/', label: 'Sinus Infections' },
      { href: '/allergies/', label: 'Allergies' },
      { href: '/pink-eye/', label: 'Pink Eye' },
    ],
  },
  {
    label: 'Chronic Conditions',
    items: [
      { href: '/diabetes/', label: 'Diabetes' },
      { href: '/cholesterol/', label: 'Cholesterol' },
      { href: '/thyroid/', label: 'Thyroid' },
    ],
  },
  {
    label: 'Lifestyle',
    items: [
      { href: '/smoking-cessation/', label: 'Smoking Cessation' },
      { href: '/sexual-health/', label: 'Sexual Health' },
    ],
  },
  {
    label: 'GI Health',
    items: [
      { href: '/gerd/', label: 'GERD' },
      { href: '/ibs/', label: 'IBS' },
    ],
  },
];

const allServicePaths = ['/services/', ...serviceCategories.flatMap(c => c.items.map(i => i.href))];
const isServicePage = allServicePaths.includes(currentPath);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 header-base">
  <nav class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="flex items-center justify-between h-20 lg:h-[100px]">

      <!-- Logo -->
      <a href="/" class="flex items-center mt-6 lg:mt-8">
        <img
          src="/logo-dark.png"
          alt="MBS Medical"
          class="h-28 lg:h-36 w-auto transition-all duration-500"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        <a
          href="/"
          class:list={[
            'nav-link font-ui text-[11px] font-semibold uppercase tracking-[0.15em] transition-colors duration-300 py-2',
            currentPath === '/'
              ? 'text-primary underline underline-offset-4 decoration-primary'
              : 'text-text/80 hover:text-accent',
          ]}
        >
          Home
        </a>

        <!-- Services Mega Menu -->
        <div class="relative" id="services-dropdown">
          <button
            type="button"
            id="services-trigger"
            aria-expanded="false"
            aria-controls="services-mega"
            aria-haspopup="true"
            class:list={[
              'nav-link font-ui text-[11px] font-semibold uppercase tracking-[0.15em] transition-colors duration-300 flex items-center gap-1.5 py-2 bg-transparent border-none cursor-pointer',
              isServicePage
                ? 'text-primary'
                : 'text-text/80 hover:text-accent',
            ]}
          >
            Services
            <svg class="w-3 h-3 opacity-50 transition-all duration-300 services-chevron" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="services-mega" role="menu" aria-labelledby="services-trigger" class="absolute top-full pt-2 opacity-0 invisible transition-all duration-300 translate-y-1 services-mega-panel" style="right: -200px;">
            <div class="bg-[#0F0F0F]/95 backdrop-blur-xl border border-border rounded-2xl py-5 px-6 shadow-2xl shadow-black/50">
              <div class="mb-4 pb-3 border-b border-border">
                <a href="/services/" class="font-ui text-[10px] font-bold uppercase tracking-[0.15em] text-primary hover:text-accent transition-colors duration-300">
                  View All Services →
                </a>
              </div>
              <div class="grid grid-cols-3 gap-x-8 gap-y-5" style="min-width: 560px;">
                {serviceCategories.map((cat) => (
                  <div>
                    <p class="font-ui text-[9px] font-bold uppercase tracking-[0.18em] text-text/30 mb-2">{cat.label}</p>
                    <div class="flex flex-col gap-1">
                      {cat.items.map((item) => (
                        <a
                          href={item.href}
                          class:list={[
                            'font-ui text-[10px] font-semibold uppercase tracking-[0.12em] py-1.5 px-2 rounded-md transition-colors duration-300 whitespace-nowrap',
                            currentPath === item.href
                              ? 'text-primary bg-primary/10'
                              : 'text-text/60 hover:text-accent hover:bg-accent/5',
                          ]}
                        >
                          {item.label}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <a
          href="/about/"
          class:list={[
            'nav-link font-ui text-[11px] font-semibold uppercase tracking-[0.15em] transition-colors duration-300 py-2',
            currentPath === '/about/'
              ? 'text-primary underline underline-offset-4 decoration-primary'
              : 'text-text/80 hover:text-accent',
          ]}
        >
          About
        </a>
        <a
          href="/contact/"
          class:list={[
            'nav-link font-ui text-[11px] font-semibold uppercase tracking-[0.15em] transition-colors duration-300 py-2',
            currentPath === '/contact/'
              ? 'text-primary underline underline-offset-4 decoration-primary'
              : 'text-text/80 hover:text-accent',
          ]}
        >
          Contact
        </a>
      </div>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-4">
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex header-cta items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-5 py-2.5 rounded-full hover:bg-accent hover:border-accent transition-all duration-300"
        >
          Book a Visit
        </a>

        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-text/80 hover:text-accent transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" id="menu-icon-open" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg class="w-6 h-6 hidden" id="menu-icon-close" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" role="navigation" aria-label="Mobile navigation" class="lg:hidden hidden pb-6 pt-4 border-t border-border bg-bg/95 backdrop-blur-xl max-h-[80vh] overflow-y-auto">
      <div class="flex flex-col gap-0.5">
        <a href="/" class:list={['font-ui text-[12px] font-semibold uppercase tracking-[0.12em] py-3 px-3 rounded-lg transition-colors duration-300', currentPath === '/' ? 'text-primary bg-primary/10' : 'text-text/70 hover:text-accent hover:bg-accent/5']}>Home</a>

        <!-- Services section with accordion categories -->
        <div class="mt-2 mb-1">
          <a href="/services/" class:list={['font-ui text-[12px] font-semibold uppercase tracking-[0.12em] py-3 px-3 rounded-lg transition-colors duration-300 block', currentPath === '/services/' ? 'text-primary bg-primary/10' : 'text-text/70 hover:text-accent hover:bg-accent/5']}>All Services</a>
        </div>

        {serviceCategories.map((cat, catIdx) => (
          <div class="mobile-cat">
            <button
              class="mobile-cat-toggle w-full flex items-center justify-between font-ui text-[11px] font-bold uppercase tracking-[0.12em] py-3 px-3 rounded-lg text-text/60 hover:text-accent hover:bg-accent/5 transition-colors duration-300"
              aria-expanded="false"
              type="button"
            >
              <span class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary/50 shrink-0"></span>
                {cat.label}
              </span>
              <svg class="w-3.5 h-3.5 transition-transform duration-300 shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="mobile-cat-items hidden flex-col gap-0.5 pl-3 pb-1">
              {cat.items.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'font-ui text-[11px] font-semibold uppercase tracking-[0.1em] py-2.5 pl-5 border-l-2 transition-colors duration-300 rounded-r-lg',
                    currentPath === item.href
                      ? 'text-primary border-primary bg-primary/5'
                      : 'text-text/50 border-border hover:text-accent hover:border-accent hover:bg-accent/5',
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        ))}

        <div class="border-t border-border mt-3 pt-3 flex flex-col gap-0.5">
          <a href="/about/" class:list={['font-ui text-[12px] font-semibold uppercase tracking-[0.12em] py-3 px-3 rounded-lg transition-colors duration-300', currentPath === '/about/' ? 'text-primary bg-primary/10' : 'text-text/70 hover:text-accent hover:bg-accent/5']}>About</a>
          <a href="/contact/" class:list={['font-ui text-[12px] font-semibold uppercase tracking-[0.12em] py-3 px-3 rounded-lg transition-colors duration-300', currentPath === '/contact/' ? 'text-primary bg-primary/10' : 'text-text/70 hover:text-accent hover:bg-accent/5']}>Contact</a>
        </div>
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 text-center font-ui text-[11px] font-bold uppercase tracking-[0.12em] bg-primary text-bg border border-primary px-5 py-3 rounded-full hover:bg-accent hover:border-accent transition-all duration-300"
        >
          Book a Visit
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  .header-base {
    background: linear-gradient(to bottom, rgba(8, 8, 8, 0.9) 0%, rgba(8, 8, 8, 0.7) 60%, rgba(8, 8, 8, 0.3) 85%, transparent 100%);
    padding-bottom: 60px;
    margin-bottom: -60px;
  }
  .header-scrolled {
    background: rgba(8, 8, 8, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(237, 233, 224, 0.06);
  }
  .services-mega-panel.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .services-chevron.is-open {
    transform: rotate(180deg);
    opacity: 1;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      const menuOpen = !document.getElementById('mobile-menu')?.classList.contains('hidden');
      header.classList.toggle('header-scrolled', window.scrollY > 60 || menuOpen);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Desktop mega-menu: click + hover hybrid
  const servicesTrigger = document.getElementById('services-trigger');
  const servicesMega = document.getElementById('services-mega');
  const servicesChevron = servicesTrigger?.querySelector('.services-chevron');
  const servicesDropdown = document.getElementById('services-dropdown');

  function openMega() {
    servicesMega?.classList.add('is-open');
    servicesChevron?.classList.add('is-open');
    servicesTrigger?.setAttribute('aria-expanded', 'true');
  }
  function closeMega() {
    servicesMega?.classList.remove('is-open');
    servicesChevron?.classList.remove('is-open');
    servicesTrigger?.setAttribute('aria-expanded', 'false');
  }

  // Click toggles
  servicesTrigger?.addEventListener('click', (e) => {
    e.preventDefault();
    if (servicesMega?.classList.contains('is-open')) {
      closeMega();
    } else {
      openMega();
    }
  });

  // Hover open/close on the whole dropdown container (desktop)
  let hoverTimeout: ReturnType<typeof setTimeout>;
  servicesDropdown?.addEventListener('mouseenter', () => {
    clearTimeout(hoverTimeout);
    openMega();
  });
  servicesDropdown?.addEventListener('mouseleave', () => {
    hoverTimeout = setTimeout(closeMega, 200);
  });

  // Close when clicking outside
  document.addEventListener('click', (e) => {
    if (!servicesDropdown?.contains(e.target as Node)) {
      closeMega();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMega();
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    const isOpening = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', isOpening ? 'true' : 'false');
    btn.setAttribute('aria-label', isOpening ? 'Close navigation menu' : 'Open navigation menu');
    if (isOpening) {
      header?.classList.add('header-scrolled');
    } else if (window.scrollY <= 60) {
      header?.classList.remove('header-scrolled');
    }
  });

  // Mobile category accordion toggles
  document.querySelectorAll('.mobile-cat-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const items = toggle.nextElementSibling as HTMLElement;
      const isOpen = !items.classList.contains('hidden');
      // Close all
      document.querySelectorAll('.mobile-cat-items').forEach((el) => {
        el.classList.add('hidden');
        el.classList.remove('flex');
      });
      document.querySelectorAll('.mobile-cat-toggle').forEach((el) => {
        el.setAttribute('aria-expanded', 'false');
        el.querySelector('svg')?.classList.remove('rotate-180');
      });
      // Open clicked if was closed
      if (!isOpen) {
        items.classList.remove('hidden');
        items.classList.add('flex');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.querySelector('svg')?.classList.add('rotate-180');
      }
    });
  });

  // Auto-expand the category containing the current page
  const currentCat = document.querySelector('.mobile-cat-items a[class*="text-primary"]')?.closest('.mobile-cat');
  if (currentCat) {
    const items = currentCat.querySelector('.mobile-cat-items') as HTMLElement;
    const toggle = currentCat.querySelector('.mobile-cat-toggle') as HTMLElement;
    if (items && toggle) {
      items.classList.remove('hidden');
      items.classList.add('flex');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.querySelector('svg')?.classList.add('rotate-180');
    }
  }
</script>
