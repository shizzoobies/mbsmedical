---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  {
    href: '/services/',
    label: 'Services',
    children: [
      { href: '/primary-care/', label: 'Primary Care' },
      { href: '/weight-loss/', label: 'Weight Loss' },
      { href: '/trt/', label: 'TRT Evaluation' },
    ],
  },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

const isServicePage = ['/services/', '/primary-care/', '/weight-loss/', '/trt/'].includes(currentPath);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <nav class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="flex items-center justify-between h-20 lg:h-[100px]">

      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img
          src="/logo.png"
          alt="MBS Medical"
          class="h-28 lg:h-36 w-auto transition-all duration-500"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          link.children ? (
            <!-- Dropdown -->
            <div class="relative group">
              <a
                href={link.href}
                class:list={[
                  'nav-link font-ui text-[11px] font-semibold uppercase tracking-[0.15em] transition-colors duration-300 flex items-center gap-1.5 py-2',
                  isServicePage
                    ? 'text-primary'
                    : 'text-text/80 hover:text-accent',
                ]}
              >
                {link.label}
                <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-all duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0">
                <div class="bg-surface-light/95 backdrop-blur-xl border border-border rounded-lg py-3 px-2 min-w-[200px] shadow-2xl shadow-black/40">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2.5 rounded-md font-ui text-[10px] font-semibold uppercase tracking-[0.12em] transition-colors duration-300',
                        currentPath === child.href
                          ? 'text-primary bg-primary/10'
                          : 'text-text/70 hover:text-accent hover:bg-accent/5',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'nav-link font-ui text-[11px] font-semibold uppercase tracking-[0.15em] transition-colors duration-300 py-2',
                currentPath === link.href
                  ? 'text-primary underline underline-offset-4 decoration-primary'
                  : 'text-text/80 hover:text-accent',
              ]}
            >
              {link.label}
            </a>
          )
        ))}
      </div>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-4">
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex header-cta items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-5 py-2.5 rounded-[4px] hover:bg-accent hover:border-accent transition-all duration-300"
        >
          Book a Visit
        </a>

        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-text/80 hover:text-accent transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="lg:hidden hidden pb-6 pt-4 border-t border-border">
      <div class="flex flex-col gap-1">
        <a href="/" class:list={['font-ui text-[11px] font-semibold uppercase tracking-[0.15em] py-2.5 transition-colors duration-300', currentPath === '/' ? 'text-primary' : 'text-text/60 hover:text-accent']}>Home</a>
        <a href="/services/" class:list={['font-ui text-[11px] font-semibold uppercase tracking-[0.15em] py-2.5 transition-colors duration-300', currentPath === '/services/' ? 'text-primary' : 'text-text/60 hover:text-accent']}>Services</a>
        <a href="/primary-care/" class:list={['font-ui text-[10px] font-semibold uppercase tracking-[0.12em] py-2 pl-4 border-l border-border transition-colors duration-300', currentPath === '/primary-care/' ? 'text-primary border-primary' : 'text-text/40 hover:text-accent hover:border-accent']}>Primary Care</a>
        <a href="/weight-loss/" class:list={['font-ui text-[10px] font-semibold uppercase tracking-[0.12em] py-2 pl-4 border-l border-border transition-colors duration-300', currentPath === '/weight-loss/' ? 'text-primary border-primary' : 'text-text/40 hover:text-accent hover:border-accent']}>Weight Loss</a>
        <a href="/trt/" class:list={['font-ui text-[10px] font-semibold uppercase tracking-[0.12em] py-2 pl-4 border-l border-border transition-colors duration-300', currentPath === '/trt/' ? 'text-primary border-primary' : 'text-text/40 hover:text-accent hover:border-accent']}>TRT Evaluation</a>
        <a href="/about/" class:list={['font-ui text-[11px] font-semibold uppercase tracking-[0.15em] py-2.5 transition-colors duration-300', currentPath === '/about/' ? 'text-primary' : 'text-text/60 hover:text-accent']}>About</a>
        <a href="/contact/" class:list={['font-ui text-[11px] font-semibold uppercase tracking-[0.15em] py-2.5 transition-colors duration-300', currentPath === '/contact/' ? 'text-primary' : 'text-text/60 hover:text-accent']}>Contact</a>
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 text-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-5 py-2.5 rounded-[4px]"
        >
          Book a Visit
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  .header-scrolled {
    background: rgba(8, 8, 8, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(237, 233, 224, 0.06);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('header-scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
