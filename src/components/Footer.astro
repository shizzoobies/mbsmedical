---
const serviceLinks = [
  { href: '/services/', label: 'All Services' },
  { href: '/primary-care/', label: 'Primary Care' },
  { href: '/weight-loss/', label: 'Weight Loss' },
  { href: '/trt/', label: 'TRT Evaluation' },
];

const practiceLinks = [
  { href: '/about/', label: 'About Us' },
  { href: '/contact/', label: 'Contact' },
];
---

<footer class="border-t border-border">
  <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 py-20 lg:py-28">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Brand -->
      <div>
        <img src="/logo.png" alt="MBS Medical" class="h-12 w-auto brightness-0 invert mb-6" />
        <p class="text-text-muted text-base leading-relaxed max-w-[280px]">
          Telehealth medical care across Florida. Cash pay, no insurance. Same-week appointments.
        </p>
      </div>

      <!-- Navigate -->
      <div>
        <h4 class="label text-text-muted mb-6">Navigate</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-text text-base hover:text-primary transition-colors duration-300">Home</a></li>
          <li><a href="/services/" class="text-text text-base hover:text-primary transition-colors duration-300">Services</a></li>
          <li><a href="/about/" class="text-text text-base hover:text-primary transition-colors duration-300">About</a></li>
          <li><a href="/contact/" class="text-text text-base hover:text-primary transition-colors duration-300">Contact</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="label text-text-muted mb-6">Services</h4>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text text-base hover:text-primary transition-colors duration-300">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h4 class="label text-text-muted mb-6">Hours</h4>
        <p class="text-text text-base mb-1">Monday &ndash; Friday</p>
        <p class="text-text text-base mb-6">8:00 AM &ndash; 6:00 PM</p>
        <a
          href="https://mbsmedical.practicebetter.io"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center font-ui text-[10px] font-bold uppercase tracking-[0.15em] bg-primary text-bg border border-primary px-5 py-2.5 rounded-[4px] hover:bg-primary-light hover:border-primary-light transition-all duration-300"
        >
          Book a Visit
        </a>
      </div>

    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-border">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-text-muted text-sm">&copy; {new Date().getFullYear()} MBS Medical. All rights reserved.</p>
      <p class="text-text-muted text-sm">For medical emergencies, call 911.</p>
    </div>
  </div>
</footer>
