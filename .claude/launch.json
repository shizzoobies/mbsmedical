{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static site (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "mbs-medical-starter", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Static site (Python http.server)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "mbs-medical-starter"],
      "port": 8080
    }
  ]
}
